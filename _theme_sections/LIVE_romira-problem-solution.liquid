{%- style -%}
  .romira-reveal-{{ section.id }} {
    background-color: {{ section.settings.outer_bg }};
    overflow-x: hidden;
  }
  .romira-reveal-{{ section.id }} .rr-part1 {
    padding-top: {{ section.settings.p1_pad_top_mobile }}px;
    padding-bottom: {{ section.settings.p1_pad_bottom_mobile }}px;
    background-color: {{ section.settings.p1_bg }};
  }
  @media (min-width: 750px) {
    .romira-reveal-{{ section.id }} .rr-part1 {
      padding-top: {{ section.settings.p1_pad_top }}px;
      padding-bottom: {{ section.settings.p1_pad_bottom }}px;
    }
  }
  .romira-reveal-{{ section.id }} .rr-p1-inner {
    max-width: {{ section.settings.content_width }}px;
    margin: 0 auto;
    padding: 0 {{ section.settings.p1_h_pad_mobile }}px;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.p1_gap_mobile }}px;
  }
  @media (min-width: 750px) {
    .romira-reveal-{{ section.id }} .rr-p1-inner {
      flex-direction: row;
      align-items: center;
      gap: {{ section.settings.p1_gap }}px;
      padding: 0 {{ section.settings.p1_h_pad }}px;
    }
    .romira-reveal-{{ section.id }} .rr-p1-inner.img-right {
      flex-direction: row-reverse;
    }
  }
  .romira-reveal-{{ section.id }} .rr-p1-image {
    width: 100%;
    flex-shrink: 0;
    border-radius: {{ section.settings.p1_img_radius }}px;
    overflow: hidden;
    opacity: 0;
    transform: translateX(-30px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  @media (min-width: 750px) {
    .romira-reveal-{{ section.id }} .rr-p1-image {
      width: {{ section.settings.p1_img_width }}%;
    }
  }
  .romira-reveal-{{ section.id }} .rr-p1-image.rr-visible { opacity: 1; transform: translateX(0); }
  .romira-reveal-{{ section.id }} .rr-p1-image img {
    width: 100%;
    display: block;
    object-fit: cover;
    aspect-ratio: {{ section.settings.p1_img_ratio_mobile }};
  }
  @media (min-width: 750px) {
    .romira-reveal-{{ section.id }} .rr-p1-image img { aspect-ratio: {{ section.settings.p1_img_ratio }}; }
  }
  .romira-reveal-{{ section.id }} .rr-p1-img-placeholder {
    width: 100%;
    aspect-ratio: {{ section.settings.p1_img_ratio_mobile }};
    background: #1a2e1a;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #666;
    font-size: 14px;
  }
  @media (min-width: 750px) {
    .romira-reveal-{{ section.id }} .rr-p1-img-placeholder { aspect-ratio: {{ section.settings.p1_img_ratio }}; }
  }
  .romira-reveal-{{ section.id }} .rr-p1-content {
    flex: 1;
    min-width: 0;
    opacity: 0;
    transform: translateX(30px);
    transition: opacity 0.7s ease 0.2s, transform 0.7s ease 0.2s;
  }
  .romira-reveal-{{ section.id }} .rr-p1-content.rr-visible { opacity: 1; transform: translateX(0); }
  .romira-reveal-{{ section.id }} .rr-p1-heading {
    font-size: {{ section.settings.p1_heading_size_mobile }}px !important;
    color: {{ section.settings.p1_heading_color }};
    font-weight: {{ section.settings.p1_heading_weight }};
    margin: 0 0 {{ section.settings.p1_heading_gap }}px;
    line-height: 1.2;
    word-wrap: break-word;
  }
  @media (min-width: 750px) {
    .romira-reveal-{{ section.id }} .rr-p1-heading { font-size: {{ section.settings.p1_heading_size }}px !important; }
  }
  .romira-reveal-{{ section.id }} .rr-p1-heading em { color: {{ section.settings.p1_heading_highlight }}; font-style: normal; }
  .romira-reveal-{{ section.id }} .rr-p1-body {
    font-size: {{ section.settings.p1_body_size_mobile }}px;
    color: {{ section.settings.p1_body_color }};
    line-height: 1.7;
    margin: 0 0 {{ section.settings.p1_body_gap }}px;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }
  @media (min-width: 750px) {
    .romira-reveal-{{ section.id }} .rr-p1-body { font-size: {{ section.settings.p1_body_size }}px; }
  }
  .romira-reveal-{{ section.id }} .rr-p1-body p { margin: 0 0 8px; }
  .romira-reveal-{{ section.id }} .rr-p1-body p:last-child { margin: 0; }
  .romira-reveal-{{ section.id }} .rr-bullets {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.bullet_gap }}px;
  }
  .romira-reveal-{{ section.id }} .rr-bullet {
    display: flex;
    align-items: flex-start;
    gap: {{ section.settings.bullet_icon_gap }}px;
    font-size: {{ section.settings.bullet_size_mobile }}px;
    color: {{ section.settings.bullet_color }};
    line-height: 1.5;
    word-wrap: break-word;
  }
  @media (min-width: 750px) {
    .romira-reveal-{{ section.id }} .rr-bullet { font-size: {{ section.settings.bullet_size }}px; }
  }
  .romira-reveal-{{ section.id }} .rr-bullet-icon {
    width: {{ section.settings.bullet_icon_size }}px;
    height: {{ section.settings.bullet_icon_size }}px;
    border-radius: {{ section.settings.bullet_icon_radius }}px;
    background: {{ section.settings.bullet_icon_bg }};
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: {{ section.settings.bullet_icon_color }};
    font-size: {{ section.settings.bullet_icon_font_size }}px;
    font-weight: 700;
    margin-top: 2px;
  }
  .romira-reveal-{{ section.id }} .rr-part2-wrap {
    max-width: {{ section.settings.content_width }}px;
    margin: 0 auto;
    padding: {{ section.settings.p2_wrap_pad_mobile }}px {{ section.settings.p1_h_pad_mobile }}px;
    box-sizing: border-box;
  }
  @media (min-width: 750px) {
    .romira-reveal-{{ section.id }} .rr-part2-wrap { padding: {{ section.settings.p2_wrap_pad }}px {{ section.settings.p1_h_pad }}px; }
  }
  .romira-reveal-{{ section.id }} .rr-part2 {
    background-color: {{ section.settings.p2_bg }};
    border-radius: {{ section.settings.p2_radius }}px;
    padding: {{ section.settings.p2_pad_mobile }}px;
    display: flex;
    flex-direction: column;
    gap: 28px;
    overflow: hidden;
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s ease, transform 0.7s ease;
    box-sizing: border-box;
  }
  @media (min-width: 750px) {
    .romira-reveal-{{ section.id }} .rr-part2 {
      flex-direction: row;
      align-items: center;
      padding: {{ section.settings.p2_pad }}px;
      gap: {{ section.settings.p2_gap }}px;
    }
    .romira-reveal-{{ section.id }} .rr-part2.prod-left { flex-direction: row-reverse; }
  }
  .romira-reveal-{{ section.id }} .rr-part2.rr-visible { opacity: 1; transform: translateY(0); }
  .romira-reveal-{{ section.id }} .rr-p2-content { flex: 1; min-width: 0; }
  .romira-reveal-{{ section.id }} .rr-p2-eyebrow {
    font-size: {{ section.settings.p2_eyebrow_size }}px !important;
    font-weight: {{ section.settings.p2_eyebrow_weight }};
    letter-spacing: {{ section.settings.p2_eyebrow_spacing }}px;
    text-transform: {{ section.settings.p2_eyebrow_transform }};
    color: {{ section.settings.p2_eyebrow_color }};
    margin: 0 0 12px;
    display: block;
  }
  .romira-reveal-{{ section.id }} .rr-p2-heading {
    font-size: {{ section.settings.p2_heading_size_mobile }}px !important;
    font-weight: {{ section.settings.p2_heading_weight }};
    color: {{ section.settings.p2_heading_color }};
    margin: 0 0 16px;
    line-height: 1.2;
    word-wrap: break-word;
  }
  @media (min-width: 750px) {
    .romira-reveal-{{ section.id }} .rr-p2-heading { font-size: {{ section.settings.p2_heading_size }}px !important; }
  }
  .romira-reveal-{{ section.id }} .rr-p2-body {
    font-size: {{ section.settings.p2_body_size_mobile }}px;
    color: {{ section.settings.p2_body_color }};
    line-height: 1.7;
    margin: 0 0 28px;
    word-wrap: break-word;
  }
  @media (min-width: 750px) {
    .romira-reveal-{{ section.id }} .rr-p2-body { font-size: {{ section.settings.p2_body_size }}px; }
  }
  .romira-reveal-{{ section.id }} .rr-p2-body p { margin: 0 0 8px; }
  .romira-reveal-{{ section.id }} .rr-p2-body p:last-child { margin: 0; }
  .romira-reveal-{{ section.id }} .rr-features {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: {{ section.settings.feat_gap_mobile }}px;
  }
  @media (min-width: 750px) {
    .romira-reveal-{{ section.id }} .rr-features {
      grid-template-columns: repeat({{ section.blocks.size | at_least: 1 }}, 1fr);
      gap: {{ section.settings.feat_gap }}px;
    }
  }
  .romira-reveal-{{ section.id }} .rr-feat {
    display: flex;
    flex-direction: column;
    align-items: {{ section.settings.feat_align }};
    gap: 8px;
    text-align: {{ section.settings.feat_text_align }};
  }
  .romira-reveal-{{ section.id }} .rr-feat-icon {
    width: {{ section.settings.feat_icon_size_mobile }}px;
    height: {{ section.settings.feat_icon_size_mobile }}px;
    object-fit: contain;
    display: block;
  }
  @media (min-width: 750px) {
    .romira-reveal-{{ section.id }} .rr-feat-icon {
      width: {{ section.settings.feat_icon_size }}px;
      height: {{ section.settings.feat_icon_size }}px;
    }
  }
  .romira-reveal-{{ section.id }} .rr-feat-emoji {
    font-size: {{ section.settings.feat_icon_size_mobile }}px;
    line-height: 1;
    display: block;
  }
  @media (min-width: 750px) {
    .romira-reveal-{{ section.id }} .rr-feat-emoji { font-size: {{ section.settings.feat_icon_size }}px; }
  }
  .romira-reveal-{{ section.id }} .rr-feat-label {
    font-size: {{ section.settings.feat_label_size_mobile }}px !important;
    font-weight: {{ section.settings.feat_label_weight }};
    color: {{ section.settings.feat_label_color }};
    line-height: 1.3;
    margin: 0;
    word-wrap: break-word;
  }
  @media (min-width: 750px) {
    .romira-reveal-{{ section.id }} .rr-feat-label { font-size: {{ section.settings.feat_label_size }}px !important; }
  }
  .romira-reveal-{{ section.id }} .rr-p2-product {
    flex-shrink: 0;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  @media (min-width: 750px) {
    .romira-reveal-{{ section.id }} .rr-p2-product { width: {{ section.settings.p2_product_width }}%; }
  }
  .romira-reveal-{{ section.id }} .rr-p2-product img {
    width: 100%;
    max-width: {{ section.settings.p2_product_max_width }}px;
    display: block;
    object-fit: contain;
    aspect-ratio: {{ section.settings.p2_product_ratio }};
  }
  .romira-reveal-{{ section.id }} .rr-p2-product-placeholder {
    width: 100%;
    max-width: {{ section.settings.p2_product_max_width }}px;
    aspect-ratio: {{ section.settings.p2_product_ratio }};
    border: 2px dashed rgba(255,255,255,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.4);
    font-size: 13px;
    border-radius: 8px;
  }
{%- endstyle -%}

<div class="romira-reveal-{{ section.id }}">
  <div class="rr-part1">
    <div class="rr-p1-inner{% if section.settings.p1_image_position == 'right' %} img-right{% endif %}">
      <div class="rr-p1-image" id="rr-img-{{ section.id }}">
        {%- if section.settings.p1_image != blank -%}
          {{ section.settings.p1_image | image_url: width: 900 | image_tag: loading: 'lazy' }}
        {%- else -%}
          <div class="rr-p1-img-placeholder">Add image in theme editor</div>
        {%- endif -%}
      </div>
      <div class="rr-p1-content" id="rr-content-{{ section.id }}">
        {%- if section.settings.p1_heading != blank -%}
          <{{ section.settings.p1_heading_tag }} class="rr-p1-heading">{{ section.settings.p1_heading }}</{{ section.settings.p1_heading_tag }}>
        {%- endif -%}
        {%- if section.settings.p1_body != blank -%}
          <div class="rr-p1-body">{{ section.settings.p1_body }}</div>
        {%- endif -%}
        {%- assign b1 = section.settings.bullet_1 -%}
        {%- assign b2 = section.settings.bullet_2 -%}
        {%- assign b3 = section.settings.bullet_3 -%}
        {%- assign b4 = section.settings.bullet_4 -%}
        {%- if b1 != blank or b2 != blank or b3 != blank or b4 != blank -%}
          <ul class="rr-bullets">
            {%- if b1 != blank -%}<li class="rr-bullet"><span class="rr-bullet-icon">{{ section.settings.bullet_icon_symbol }}</span><span>{{ b1 }}</span></li>{%- endif -%}
            {%- if b2 != blank -%}<li class="rr-bullet"><span class="rr-bullet-icon">{{ section.settings.bullet_icon_symbol }}</span><span>{{ b2 }}</span></li>{%- endif -%}
            {%- if b3 != blank -%}<li class="rr-bullet"><span class="rr-bullet-icon">{{ section.settings.bullet_icon_symbol }}</span><span>{{ b3 }}</span></li>{%- endif -%}
            {%- if b4 != blank -%}<li class="rr-bullet"><span class="rr-bullet-icon">{{ section.settings.bullet_icon_symbol }}</span><span>{{ b4 }}</span></li>{%- endif -%}
          </ul>
        {%- endif -%}
      </div>
    </div>
  </div>

  <div class="rr-part2-wrap">
    <div class="rr-part2{% if section.settings.p2_product_position == 'left' %} prod-left{% endif %}" id="rr-card-{{ section.id }}">
      <div class="rr-p2-content">
        {%- if section.settings.p2_eyebrow != blank -%}
          <span class="rr-p2-eyebrow">{{ section.settings.p2_eyebrow }}</span>
        {%- endif -%}
        {%- if section.settings.p2_heading != blank -%}
          <{{ section.settings.p2_heading_tag }} class="rr-p2-heading">{{ section.settings.p2_heading }}</{{ section.settings.p2_heading_tag }}>
        {%- endif -%}
        {%- if section.settings.p2_body != blank -%}
          <div class="rr-p2-body">{{ section.settings.p2_body }}</div>
        {%- endif -%}
        {%- if section.blocks.size > 0 -%}
          <div class="rr-features">
            {%- for block in section.blocks -%}
              <div class="rr-feat" {{ block.shopify_attributes }}>
                {%- if block.settings.icon_image != blank -%}
                  {{ block.settings.icon_image | image_url: width: 120 | image_tag: class: 'rr-feat-icon', loading: 'lazy' }}
                {%- else -%}
                  <span class="rr-feat-emoji">{{ block.settings.icon_emoji }}</span>
                {%- endif -%}
                {%- if block.settings.label != blank -%}
                  <p class="rr-feat-label">{{ block.settings.label }}</p>
                {%- endif -%}
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
      <div class="rr-p2-product">
        {%- if section.settings.p2_product_image != blank -%}
          {{ section.settings.p2_product_image | image_url: width: 600 | image_tag: loading: 'lazy' }}
        {%- else -%}
          <div class="rr-p2-product-placeholder">Add product image</div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  function observe(id, cls) {
    var el = document.getElementById(id);
    if (!el) return;
    new IntersectionObserver(function(entries, obs) {
      entries.forEach(function(e) {
        if (e.isIntersecting) { el.classList.add(cls); obs.unobserve(el); }
      });
    }, { threshold: 0.1 }).observe(el);
  }
  observe('rr-img-{{ section.id }}', 'rr-visible');
  observe('rr-content-{{ section.id }}', 'rr-visible');
  observe('rr-card-{{ section.id }}', 'rr-visible');
})();
</script>

{% schema %}
{
  "name": "Romira — Problem/Solution",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "color", "id": "outer_bg", "label": "Outer background color", "default": "#0d1f0f" },
    { "type": "range", "id": "content_width", "min": 600, "max": 1400, "step": 20, "unit": "px", "label": "Max content width", "default": 1200 },
    { "type": "header", "content": "Part 1 — Image" },
    { "type": "color", "id": "p1_bg", "label": "Part 1 background color", "default": "#0d1f0f" },
    { "type": "image_picker", "id": "p1_image", "label": "Image" },
    { "type": "select", "id": "p1_image_position", "label": "Image position (desktop)", "options": [{"value":"left","label":"Left"},{"value":"right","label":"Right"}], "default": "left" },
    { "type": "range", "id": "p1_img_width", "min": 25, "max": 60, "step": 5, "unit": "%", "label": "Image width (desktop)", "default": 45 },
    { "type": "text", "id": "p1_img_ratio", "label": "Image ratio desktop (e.g. 4/3, 1/1)", "default": "4/3" },
    { "type": "text", "id": "p1_img_ratio_mobile", "label": "Image ratio mobile (e.g. 16/9)", "default": "16/9" },
    { "type": "range", "id": "p1_img_radius", "min": 0, "max": 24, "step": 2, "unit": "px", "label": "Image border radius", "default": 8 },
    { "type": "header", "content": "Part 1 — Heading" },
    { "type": "text", "id": "p1_heading", "label": "Heading", "default": "The Real Reason Your Nerves Won't Stop Burning" },
    { "type": "select", "id": "p1_heading_tag", "label": "Heading tag", "options": [{"value":"h1","label":"H1"},{"value":"h2","label":"H2"},{"value":"h3","label":"H3"}], "default": "h2" },
    { "type": "range", "id": "p1_heading_size", "min": 18, "max": 60, "step": 1, "unit": "px", "label": "Heading size (desktop)", "default": 36 },
    { "type": "range", "id": "p1_heading_size_mobile", "min": 16, "max": 40, "step": 1, "unit": "px", "label": "Heading size (mobile)", "default": 24 },
    { "type": "select", "id": "p1_heading_weight", "label": "Heading weight", "options": [{"value":"400","label":"Regular"},{"value":"600","label":"Semi-bold"},{"value":"700","label":"Bold"},{"value":"800","label":"Extra bold"}], "default": "700" },
    { "type": "color", "id": "p1_heading_color", "label": "Heading color", "default": "#ffffff" },
    { "type": "color", "id": "p1_heading_highlight", "label": "Highlight color (wrap words in em tags)", "default": "#4caf7d" },
    { "type": "range", "id": "p1_heading_gap", "min": 8, "max": 40, "step": 4, "unit": "px", "label": "Heading bottom gap", "default": 16 },
    { "type": "header", "content": "Part 1 — Body text" },
    { "type": "richtext", "id": "p1_body", "label": "Body text", "default": "<p>Your nerve cells are the most energy-hungry cells in your body. They need constant fuel just to stay alive, send signals, and repair themselves. When that fuel runs out — your nerves are the first to break down. And once they start, they do not stop on their own.</p>" },
    { "type": "range", "id": "p1_body_size", "min": 13, "max": 22, "step": 1, "unit": "px", "label": "Body size (desktop)", "default": 16 },
    { "type": "range", "id": "p1_body_size_mobile", "min": 13, "max": 18, "step": 1, "unit": "px", "label": "Body size (mobile)", "default": 14 },
    { "type": "color", "id": "p1_body_color", "label": "Body text color", "default": "#cccccc" },
    { "type": "range", "id": "p1_body_gap", "min": 8, "max": 40, "step": 4, "unit": "px", "label": "Body bottom gap", "default": 24 },
    { "type": "header", "content": "Part 1 — Bullet points" },
    { "type": "text", "id": "bullet_1", "label": "Bullet 1", "default": "Burning and tingling that gets worse at night" },
    { "type": "text", "id": "bullet_2", "label": "Bullet 2", "default": "Numbness spreading through your feet, toes, and hands" },
    { "type": "text", "id": "bullet_3", "label": "Bullet 3", "default": "Pins and needles waking you up at 3am" },
    { "type": "text", "id": "bullet_4", "label": "Bullet 4", "default": "Pain your doctor says you just have to manage" },
    { "type": "range", "id": "bullet_size", "min": 13, "max": 20, "step": 1, "unit": "px", "label": "Bullet text size (desktop)", "default": 15 },
    { "type": "range", "id": "bullet_size_mobile", "min": 12, "max": 18, "step": 1, "unit": "px", "label": "Bullet text size (mobile)", "default": 14 },
    { "type": "color", "id": "bullet_color", "label": "Bullet text color", "default": "#ffffff" },
    { "type": "range", "id": "bullet_gap", "min": 8, "max": 28, "step": 2, "unit": "px", "label": "Gap between bullets", "default": 14 },
    { "type": "text", "id": "bullet_icon_symbol", "label": "Bullet icon symbol", "default": "✓" },
    { "type": "range", "id": "bullet_icon_size", "min": 16, "max": 40, "step": 2, "unit": "px", "label": "Icon circle size", "default": 24 },
    { "type": "range", "id": "bullet_icon_font_size", "min": 8, "max": 20, "step": 1, "unit": "px", "label": "Icon symbol size", "default": 12 },
    { "type": "range", "id": "bullet_icon_radius", "min": 0, "max": 20, "step": 2, "unit": "px", "label": "Icon border radius", "default": 4 },
    { "type": "range", "id": "bullet_icon_gap", "min": 6, "max": 24, "step": 2, "unit": "px", "label": "Icon to text gap", "default": 12 },
    { "type": "color", "id": "bullet_icon_bg", "label": "Icon background color", "default": "#264165" },
    { "type": "color", "id": "bullet_icon_color", "label": "Icon symbol color", "default": "#ffffff" },
    { "type": "header", "content": "Part 1 — Spacing" },
    { "type": "range", "id": "p1_pad_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding top (desktop)", "default": 60 },
    { "type": "range", "id": "p1_pad_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding bottom (desktop)", "default": 60 },
    { "type": "range", "id": "p1_pad_top_mobile", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top (mobile)", "default": 36 },
