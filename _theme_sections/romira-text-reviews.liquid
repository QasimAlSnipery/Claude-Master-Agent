      "label": "Eyebrow size",
      "default": 13
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Verified Customer Reviews"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 24,
      "max": 72,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 48
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 18,
