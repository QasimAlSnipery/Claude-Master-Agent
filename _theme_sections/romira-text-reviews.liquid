{%- liquid
  assign section_bg     = section.settings.section_bg
  assign eyebrow        = section.settings.eyebrow
  assign eyebrow_color  = section.settings.eyebrow_color
  assign eyebrow_size   = section.settings.eyebrow_size
  assign heading        = section.settings.heading
  assign heading_color  = section.settings.heading_color
  assign heading_size   = section.settings.heading_size
  assign heading_size_m = section.settings.heading_size_mobile
  assign show_rating    = section.settings.show_overall_rating
  assign rating_text    = section.settings.overall_rating_text
  assign o_star_color   = section.settings.overall_star_color
  assign show_divider   = section.settings.show_divider
  assign divider_color  = section.settings.divider_color
  assign c_star_color   = section.settings.card_star_color
  assign body_color     = section.settings.body_color
  assign name_color     = section.settings.name_color
  assign verified_color = section.settings.verified_color
  assign col_gap        = section.settings.col_gap
  assign btn_text       = section.settings.btn_text
  assign btn_style      = section.settings.btn_style
  assign btn_text_color = section.settings.btn_text_color
  assign btn_bg         = section.settings.btn_bg
  assign btn_border     = section.settings.btn_border_color
  assign btn_radius     = section.settings.btn_radius
  assign target_section = section.settings.target_section
  assign pt             = section.settings.padding_top
  assign pb             = section.settings.padding_bottom
  assign ph             = section.settings.padding_h
  assign ph_m           = section.settings.padding_h_mobile
  assign max_w          = section.settings.max_width
-%}

<style>
  #shopify-section-{{ section.id }} {
    background-color: {{ section_bg }};
    padding-top: 0 !important;
    padding-bottom: 0 !important;
  }

  .rtr-outer-{{ section.id }} {
    background-color: {{ section_bg }};
    padding-top: {{ pt | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ pb | times: 0.75 | round: 0 }}px;
    padding-left: {{ ph_m }}rem;
    padding-right: {{ ph_m }}rem;
  }

  .rtr-inner-{{ section.id }} {
    max-width: {{ max_w }}px;
    margin: 0 auto;
  }

  /* ── Header ── */
  .rtr-header-{{ section.id }} {
    text-align: center;
    margin-bottom: 20px;
  }

  .rtr-eyebrow-{{ section.id }} {
    font-size: {{ eyebrow_size }}px;
    color: {{ eyebrow_color }};
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0 0 8px;
  }

  .rtr-heading-{{ section.id }} {
    font-size: {{ heading_size_m }}px;
    color: {{ heading_color }};
    font-weight: 700;
    line-height: 1.2;
    margin: 0 0 14px;
  }

  .rtr-overall-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 15px;
    color: {{ heading_color }};
    flex-wrap: wrap;
    justify-content: center;
  }

  .rtr-ostars-{{ section.id }} {
    display: flex;
    gap: 3px;
  }

  .rtr-ostar-{{ section.id }} {
    width: 22px;
    height: 22px;
    background: {{ o_star_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 2px;
    flex-shrink: 0;
  }

  .rtr-ostar-{{ section.id }} svg { width: 65%; height: 65%; }

  /* ── Divider ── */
  .rtr-divider-{{ section.id }} {
    border: none;
    border-top: 1px solid {{ divider_color }};
    margin: 24px 0 36px;
  }

  /* ── Grid ── */
  .rtr-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: 36px;
  }

  /* ── Card ── */
  .rtr-card-{{ section.id }} {
    display: flex;
    flex-direction: column;
  }

  .rtr-card-top-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 14px;
  }

  .rtr-cstars-{{ section.id }} {
    display: flex;
    gap: 3px;
  }

  .rtr-cstar-{{ section.id }} {
    width: 20px;
    height: 20px;
    background: {{ c_star_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 2px;
    flex-shrink: 0;
  }

  .rtr-cstar-{{ section.id }} svg { width: 65%; height: 65%; }

  .rtr-card-rating-{{ section.id }} {
    font-size: 15px;
    font-weight: 600;
    color: {{ body_color }};
  }

  .rtr-card-body-{{ section.id }} {
    font-size: 15px;
    color: {{ body_color }};
    line-height: 1.7;
    margin: 0 0 18px;
  }

  .rtr-card-reviewer-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: auto;
  }

  .rtr-avatar-{{ section.id }} {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    background: #d0d0d0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .rtr-avatar-{{ section.id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .rtr-avatar-placeholder-{{ section.id }} {
    font-size: 16px;
    font-weight: 700;
    color: #888;
  }

  .rtr-reviewer-name-{{ section.id }} {
    font-size: 14px;
    color: {{ name_color }};
    font-weight: 600;
  }

  .rtr-verified-{{ section.id }} {
    font-size: 14px;
    color: {{ verified_color }};
    font-weight: 400;
  }

  /* ── Footer / button ── */
  .rtr-footer-{{ section.id }} {
    text-align: center;
    margin-top: 48px;
  }

  .rtr-btn-{{ section.id }} {
    display: inline-block;
    cursor: pointer;
    font-size: 16px;
    font-weight: 700;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .rtr-btn-{{ section.id }}:hover { opacity: 0.75; }

  .rtr-btn--button-{{ section.id }} {
    padding: 13px 32px;
    background: {{ btn_bg }};
    color: {{ btn_text_color }};
    border: 2px solid {{ btn_border }};
    border-radius: {{ btn_radius }}px;
  }

  .rtr-btn--underline-{{ section.id }} {
    background: none;
    border: none;
    padding: 0;
    color: {{ btn_text_color }};
    text-decoration: underline !important;
    text-underline-offset: 3px;
  }

  /* ── Desktop ── */
  @media (min-width: 750px) {
    .rtr-outer-{{ section.id }} {
      padding-top: {{ pt }}px;
      padding-bottom: {{ pb }}px;
      padding-left: {{ ph }}rem;
      padding-right: {{ ph }}rem;
    }

    .rtr-heading-{{ section.id }} {
      font-size: {{ heading_size }}px;
    }

    .rtr-grid-{{ section.id }} {
      grid-template-columns: repeat(3, 1fr);
      gap: {{ col_gap }}px;
    }
  }
  /* Scroll-in animations */
  .rtr-header-{{ section.id }} { opacity: 0; transform: translateY(25px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .rtr-header-{{ section.id }}.rtr-in { opacity: 1; transform: translateY(0); }
  .rtr-card-{{ section.id }} { opacity: 0; transform: translateY(35px); transition: opacity 0.65s ease, transform 0.65s ease; }
  .rtr-card-{{ section.id }}.rtr-in { opacity: 1; transform: translateY(0); }
  .rtr-card-{{ section.id }}:nth-child(1) { transition-delay: 0s; }
  .rtr-card-{{ section.id }}:nth-child(2) { transition-delay: 0.1s; }
  .rtr-card-{{ section.id }}:nth-child(3) { transition-delay: 0.2s; }
  .rtr-card-{{ section.id }}:nth-child(4) { transition-delay: 0.3s; }
  .rtr-card-{{ section.id }}:nth-child(5) { transition-delay: 0.4s; }
  .rtr-card-{{ section.id }}:nth-child(6) { transition-delay: 0.5s; }
</style>

<div class="rtr-outer-{{ section.id }}">
  <div class="rtr-inner-{{ section.id }}">

    {{- '<!-- header -->' -}}
    <div class="rtr-header-{{ section.id }}">
      {%- if eyebrow != blank -%}
        <p class="rtr-eyebrow-{{ section.id }}">{{ eyebrow }}</p>
      {%- endif -%}
      {%- if heading != blank -%}
        <h2 class="rtr-heading-{{ section.id }}">{{ heading }}</h2>
      {%- endif -%}
      {%- if show_rating -%}
        <div class="rtr-overall-{{ section.id }}">
          <div class="rtr-ostars-{{ section.id }}">
            {%- for i in (1..5) -%}
              <div class="rtr-ostar-{{ section.id }}">
                <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                  <polygon points="50,5 61,35 95,35 68,57 79,91 50,70 21,91 32,57 5,35 39,35" fill="white"/>
                </svg>
              </div>
            {%- endfor -%}
          </div>
          <span>{{ rating_text }}</span>
        </div>
      {%- endif -%}
    </div>

    {%- if show_divider -%}
      <hr class="rtr-divider-{{ section.id }}">
    {%- endif -%}

    {{- '<!-- reviews grid -->' -}}
    <div class="rtr-grid-{{ section.id }}">
      {%- for block in section.blocks -%}
        {%- if block.type == 'review' -%}
          <div class="rtr-card-{{ section.id }}" {{ block.shopify_attributes }}>

            <div class="rtr-card-top-{{ section.id }}">
              <div class="rtr-cstars-{{ section.id }}">
                {%- for i in (1..block.settings.stars) -%}
                  <div class="rtr-cstar-{{ section.id }}">
                    <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                      <polygon points="50,5 61,35 95,35 68,57 79,91 50,70 21,91 32,57 5,35 39,35" fill="white"/>
                    </svg>
                  </div>
                {%- endfor -%}
              </div>
              <span class="rtr-card-rating-{{ section.id }}">{{ block.settings.rating_text }}</span>
            </div>

            <p class="rtr-card-body-{{ section.id }}">{{ block.settings.body }}</p>

            <div class="rtr-card-reviewer-{{ section.id }}">
              <div class="rtr-avatar-{{ section.id }}">
                {%- if block.settings.avatar != blank -%}
                  {{ block.settings.avatar | image_url: width: 80 | image_tag: loading: 'lazy', width: 40, height: 40 }}
                {%- else -%}
                  <span class="rtr-avatar-placeholder-{{ section.id }}">{{ block.settings.reviewer_name | slice: 0 }}</span>
                {%- endif -%}
              </div>
              <div>
                <span class="rtr-reviewer-name-{{ section.id }}">{{ block.settings.reviewer_name }}</span>
                {%- if block.settings.show_verified -%}
                  <span class="rtr-verified-{{ section.id }}"> &bull; {{ block.settings.verified_text }}</span>
                {%- endif -%}
              </div>
            </div>

          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {{- '<!-- load more -->' -}}
    {%- if btn_text != blank -%}
      <div class="rtr-footer-{{ section.id }}">
        <a href="#" id="rtr-btn-{{ section.id }}" class="rtr-btn-{{ section.id }} {% if btn_style == 'button' %}rtr-btn--button-{{ section.id }}{% else %}rtr-btn--underline-{{ section.id }}{% endif %}">{{ btn_text }}</a>
      </div>
    {%- endif -%}

  </div>
</div>

<script>
(function() {
  var btn = document.getElementById('rtr-btn-{{ section.id }}');
  if (!btn) return;
  btn.addEventListener('click', function(e) {
    e.preventDefault();
    var raw = '{{ target_section }}';
    var key = raw.toLowerCase().replace(/[\s\-]+/g, '_');
    var el = document.querySelector('[id$="__' + key + '"]')
          || document.querySelector('[id$="__' + raw + '"]')
          || document.getElementById('shopify-section-' + key)
          || document.getElementById('shopify-section-' + raw);
    if (el) {
      window.scrollTo({ top: el.getBoundingClientRect().top + window.pageYOffset, behavior: 'smooth' });
    }
  });
})();
</script>

<script>
(function() {
  var header = document.querySelector('.rtr-header-{{ section.id }}');
  var cards = document.querySelectorAll('.rtr-card-{{ section.id }}');
  var obs = new IntersectionObserver(function(entries, o) {
    entries.forEach(function(e) {
      if (e.isIntersecting) { e.target.classList.add('rtr-in'); o.unobserve(e.target); }
    });
  }, { threshold: 0.1 });
  if (header) obs.observe(header);
  cards.forEach(function(c) { obs.observe(c); });
})();
</script>

{% schema %}
{
  "name": "Romira Text Reviews",
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
