{%- assign sid = 'sscount-' | append: section.id -%}

<style>
  #{{ sid }} {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px {{ section.settings.padding_lr }}px {{ section.settings.padding_bottom }}px;
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
  }
  #{{ sid }} .sscount__inner {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: {{ section.settings.layout_align }};
    flex-wrap: wrap;
    gap: {{ section.settings.inner_gap }}px {{ section.settings.inner_gap_h }}px;
    text-align: center;
  }
  #{{ sid }} .sscount__headline {
    margin: 0;
    font-weight: 700;
    font-size: {{ section.settings.headline_size }}px;
    color: {{ section.settings.headline_color }};
    letter-spacing: 0.02em;
  }
  #{{ sid }} .sscount__hl {
    background: none;
    color: {{ section.settings.highlight_color }};
    padding: 0;
    -webkit-text-fill-color: {{ section.settings.highlight_color }};
  }
  #{{ sid }} .sscount__sub {
    margin: 0;
    font-size: {{ section.settings.sub_size }}px;
    color: {{ section.settings.sub_color }};
    opacity: {{ section.settings.sub_opacity | divided_by: 100.0 }};
  }
  #{{ sid }} .sscount__timer {
    display: flex;
    align-items: flex-start;
    gap: {{ section.settings.unit_gap }}px;
  }
  #{{ sid }} .sscount__unit {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: {{ section.settings.label_gap }}px;
  }
  #{{ sid }} .sscount__box {
    background-color: {{ section.settings.box_bg }};
    border: {{ section.settings.box_border_width }}px solid {{ section.settings.box_border_color }};
    border-radius: {{ section.settings.box_radius }}px;
    padding: {{ section.settings.box_pad_v }}px {{ section.settings.box_pad_h }}px;
    min-width: {{ section.settings.box_min_width }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  #{{ sid }} .sscount__num {
    font-size: {{ section.settings.num_size }}px;
    font-weight: 800;
    line-height: 1;
    color: {{ section.settings.num_color }};
    font-variant-numeric: tabular-nums;
    display: block;
    transition: transform 0.12s ease;
  }
  #{{ sid }} .sscount__num.flip {
    transform: scale(1.18);
  }
  #{{ sid }} .sscount__label {
    font-size: {{ section.settings.label_size }}px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: {{ section.settings.label_color }};
  }
  #{{ sid }} .sscount__colon {
    font-size: {{ section.settings.num_size }}px;
    font-weight: 800;
    color: {{ section.settings.colon_color }};
    line-height: 1;
    padding-top: {{ section.settings.box_pad_v }}px;
    {%- if section.settings.show_labels -%}
    margin-bottom: calc({{ section.settings.label_size }}px + {{ section.settings.label_gap }}px + 2px);
    {%- endif -%}
    opacity: {{ section.settings.colon_opacity | divided_by: 100.0 }};
  }
  #{{ sid }} .sscount__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ section.settings.btn_pad_v }}px {{ section.settings.btn_pad_h }}px;
    background-color: {{ section.settings.btn_bg }};
    color: {{ section.settings.btn_text_color }};
    font-weight: 700;
    font-size: {{ section.settings.btn_size }}px;
    text-decoration: none;
    border-radius: {{ section.settings.btn_radius }}px;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    white-space: nowrap;
    letter-spacing: 0.02em;
  }
  #{{ sid }} .sscount__btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0,0,0,0.28);
  }
  {%- if section.settings.hide_on_mobile -%}
  @media(max-width:749px){#{{ sid }}{display:none!important;}}
  {%- endif -%}
  @media(max-width:749px){
    #{{ sid }} .sscount__num   { font-size: {{ section.settings.num_size | times: 0.76 | round }}px; }
    #{{ sid }} .sscount__colon { font-size: {{ section.settings.num_size | times: 0.76 | round }}px; }
    #{{ sid }} .sscount__box   { min-width: {{ section.settings.box_min_width | times: 0.78 | round }}px; padding: {{ section.settings.box_pad_v | times: 0.8 | round }}px {{ section.settings.box_pad_h | times: 0.8 | round }}px; }
    #{{ sid }} .sscount__headline { font-size: {{ section.settings.headline_size | times: 0.82 | round }}px; }
    #{{ sid }} .sscount__sub   { font-size: {{ section.settings.sub_size | times: 0.9 | round }}px; }
    #{{ sid }} .sscount__inner { gap: {{ section.settings.inner_gap | times: 0.7 | round }}px; }
  }

  /* Expired state */
  #{{ sid }}-expired {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px {{ section.settings.padding_lr }}px {{ section.settings.padding_bottom }}px;
    text-align: center;
    color: {{ section.settings.headline_color }};
    font-size: {{ section.settings.headline_size }}px;
    font-weight: 700;
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
  }
</style>

<div id="{{ sid }}" role="region" aria-label="Sale countdown timer">
  <div class="sscount__inner">

    {%- if section.settings.headline != blank -%}
      <p class="sscount__headline">
        {%- if section.settings.headline_highlight != blank -%}
          {{- section.settings.headline | split: section.settings.headline_highlight | first -}}<mark class="sscount__hl">{{- section.settings.headline_highlight -}}</mark>{{- section.settings.headline | split: section.settings.headline_highlight | last -}}
        {%- else -%}
          {{- section.settings.headline -}}
        {%- endif -%}
      </p>
    {%- endif -%}

    <div class="sscount__timer" aria-live="polite">

      {%- unless section.settings.hide_hours -%}
      <div class="sscount__unit">
        <div class="sscount__box">
          <span class="sscount__num" id="{{ sid }}-hours">00</span>
        </div>
        {%- if section.settings.show_labels -%}
          <span class="sscount__label">{{ section.settings.label_hours | default: 'HRS' }}</span>
        {%- endif -%}
      </div>
      <span class="sscount__colon" aria-hidden="true">:</span>
      {%- endunless -%}

      <div class="sscount__unit">
        <div class="sscount__box">
          <span class="sscount__num" id="{{ sid }}-minutes">00</span>
        </div>
        {%- if section.settings.show_labels -%}
          <span class="sscount__label">{{ section.settings.label_mins | default: 'MINS' }}</span>
        {%- endif -%}
      </div>

      {%- unless section.settings.hide_seconds -%}
      <span class="sscount__colon" aria-hidden="true">:</span>
      <div class="sscount__unit">
        <div class="sscount__box">
          <span class="sscount__num" id="{{ sid }}-seconds">00</span>
        </div>
        {%- if section.settings.show_labels -%}
          <span class="sscount__label">{{ section.settings.label_secs | default: 'SECS' }}</span>
        {%- endif -%}
      </div>
      {%- endunless -%}

    </div>

    {%- if section.settings.sub_message != blank -%}
      <p class="sscount__sub">{{ section.settings.sub_message }}</p>
    {%- endif -%}

    {%- if section.settings.btn_label != blank -%}
      <a href="{{ section.settings.btn_link | default: '#' }}" class="sscount__btn">
        {{- section.settings.btn_label -}}
      </a>
    {%- endif -%}

  </div>
</div>

<div id="{{ sid }}-expired" style="display:none;" aria-live="polite">
  {{ section.settings.expired_message | default: 'This offer has ended.' }}
</div>

<script>
(function(){
  var sid      = {{ sid | json }};
  var endStr   = {{ section.settings.end_date | json }};
  var mode     = {{ section.settings.reset_behavior | json }};
  var hideHrs  = {{ section.settings.hide_hours  | json }};
  var hideSecs = {{ section.settings.hide_seconds | json }};

  var wrap     = document.getElementById(sid);
  var expWrap  = document.getElementById(sid + '-expired');
  var hEl      = document.getElementById(sid + '-hours');
  var mEl      = document.getElementById(sid + '-minutes');
  var sEl      = document.getElementById(sid + '-seconds');
  if (!wrap) return;

  function getEnd() {
    if (mode === 'loop24h') {
      var stored;
      try { stored = localStorage.getItem('sscount_end_' + sid); } catch(e){}
      var now = Date.now();
      if (!stored || parseInt(stored) <= now) {
        var t = now + 86400000;
        try { localStorage.setItem('sscount_end_' + sid, String(t)); } catch(e){}
        return t;
      }
      return parseInt(stored);
    }
    if (endStr) return new Date(endStr).getTime();
    return Date.now() + 86400000;
  }

  var endTime = getEnd();

  function pad(n){ return n < 10 ? '0' + n : '' + n; }

  function flip(el, val){
    if (!el) return;
    if (el.textContent === val) return;
    el.classList.remove('flip');
    void el.offsetWidth;
    el.textContent = val;
    el.classList.add('flip');
    setTimeout(function(){ el.classList.remove('flip'); }, 130);
  }

  function tick(){
    var diff = endTime - Date.now();
    if (diff <= 0){
      if (mode === 'loop24h'){
        endTime = Date.now() + 86400000;
        try { localStorage.setItem('sscount_end_' + sid, String(endTime)); } catch(e){}
        diff = endTime - Date.now();
      } else if (mode === 'hide'){
        wrap.style.display = 'none';
        return;
      } else {
        wrap.style.display = 'none';
        if (expWrap) expWrap.style.display = '';
        return;
      }
    }
    var total = Math.floor(diff / 1000);
    var h = Math.floor(total / 3600);
    var m = Math.floor((total % 3600) / 60);
    var s = total % 60;
    if (!hideHrs){
      flip(hEl, pad(h));
    } else {
      m = Math.floor(total / 60);
    }
    flip(mEl, pad(m));
    if (!hideSecs) flip(sEl, pad(s));
  }

  tick();
  setInterval(tick, 1000);
})();
</script>

{% schema %}
{
  "name": "Countdown Urgency Timer",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "header", "content": "── Content ──────────────────" },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "⚡ Sale Ends In:"
    },
    {
      "type": "text",
      "id": "headline_highlight",
      "label": "Highlight text",
      "info": "Type the exact word(s) from the headline to colour differently. Leave blank to skip."
    },
    {
      "type": "text",
      "id": "sub_message",
      "label": "Sub-message (below timer)",
      "default": "Free shipping on all orders — today only"
    },
    {
      "type": "text",
      "id": "end_date",
      "label": "Sale end date & time",
      "info": "Format: YYYY-MM-DDTHH:MM:SS e.g. 2026-12-31T23:59:00 — ignored when mode is Loop 24h",
      "default": "2026-12-31T23:59:00"
    },
    {
      "type": "select",
      "id": "reset_behavior",
      "label": "When timer hits zero",
      "options": [
        { "value": "loop24h",  "label": "Loop — reset to 24 hours" },
        { "value": "message",  "label": "Show expired message" },
        { "value": "hide",     "label": "Hide section" }
      ],
      "default": "loop24h"
    },
    {
      "type": "text",
      "id": "expired_message",
      "label": "Expired message",
      "default": "This offer has ended."
    },

    { "type": "header", "content": "── CTA Button ───────────────" },
    { "type": "text", "id": "btn_label", "label": "Button label", "default": "Shop Now →" },
    { "type": "url",  "id": "btn_link",  "label": "Button link" },

    { "type": "header", "content": "── Timer Units ──────────────" },
    {
      "type": "checkbox",
      "id": "show_labels",
      "label": "Show labels below numbers (HRS / MINS / SECS)",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "hide_hours",
      "label": "Hide hours unit",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_seconds",
      "label": "Hide seconds unit",
      "default": false
    },
    { "type": "text", "id": "label_hours", "label": "Hours label text",   "default": "HRS" },
    { "type": "text", "id": "label_mins",  "label": "Minutes label text", "default": "MINS" },
    { "type": "text", "id": "label_secs",  "label": "Seconds label text", "default": "SECS" },

    { "type": "header", "content": "── Colors ───────────────────" },
    { "type": "color", "id": "bg_color",         "label": "Section background",      "default": "#1a1a1a" },
    { "type": "color", "id": "headline_color",   "label": "Headline color",           "default": "#ffffff" },
    { "type": "color", "id": "highlight_color",  "label": "Highlight color",          "default": "#E8920A" },
    { "type": "color", "id": "sub_color",        "label": "Sub-message color",        "default": "#ffffff" },
    { "type": "color", "id": "box_bg",           "label": "Number box background",    "default": "#2a2a2a" },
    { "type": "color", "id": "box_border_color", "label": "Number box border color",  "default": "#E8920A" },
    { "type": "color", "id": "num_color",        "label": "Number color",             "default": "#E8920A" },
    { "type": "color", "id": "colon_color",      "label": "Colon color",              "default": "#E8920A" },
    { "type": "color", "id": "label_color",      "label": "Label text color (HRS/MINS/SECS)", "default": "#aaaaaa" },
    { "type": "color", "id": "btn_bg",           "label": "Button background",        "default": "#E8920A" },
    { "type": "color", "id": "btn_text_color",   "label": "Button text color",        "default": "#ffffff" },

    { "type": "header", "content": "── Font Sizes ───────────────" },
    { "type": "range", "id": "headline_size", "label": "Headline font size", "min": 12, "max": 48, "step": 1, "unit": "px", "default": 18 },
    { "type": "range", "id": "sub_size",      "label": "Sub-message font size", "min": 10, "max": 28, "step": 1, "unit": "px", "default": 14 },
    { "type": "range", "id": "num_size",      "label": "Number font size",    "min": 20, "max": 80, "step": 2, "unit": "px", "default": 42 },
    { "type": "range", "id": "label_size",    "label": "Label font size (HRS/MINS/SECS)", "min": 8, "max": 20, "step": 1, "unit": "px", "default": 11 },
    { "type": "range", "id": "btn_size",      "label": "Button font size",    "min": 10, "max": 24, "step": 1, "unit": "px", "default": 15 },

    { "type": "header", "content": "── Number Box Style ─────────" },
    { "type": "range", "id": "box_min_width",    "label": "Number box min-width",    "min": 30, "max": 100, "step": 2,  "unit": "px", "default": 58 },
    { "type": "range", "id": "box_pad_v",        "label": "Number box padding top/bottom", "min": 0, "max": 24, "step": 1, "unit": "px", "default": 8 },
    { "type": "range", "id": "box_pad_h",        "label": "Number box padding left/right", "min": 0, "max": 32, "step": 1, "unit": "px", "default": 10 },
    { "type": "range", "id": "box_radius",       "label": "Number box border radius", "min": 0, "max": 20, "step": 1, "unit": "px", "default": 6 },
    { "type": "range", "id": "box_border_width", "label": "Number box border width",  "min": 0, "max": 4,  "step": 1, "unit": "px", "default": 1 },
    { "type": "range", "id": "colon_opacity",    "label": "Colon opacity",            "min": 10, "max": 100, "step": 5, "unit": "%", "default": 70 },

    { "type": "header", "content": "── Button Style ─────────────" },
    { "type": "range", "id": "btn_pad_v",  "label": "Button padding top/bottom",  "min": 4,  "max": 24, "step": 1, "unit": "px", "default": 10 },
    { "type": "range", "id": "btn_pad_h",  "label": "Button padding left/right",  "min": 10, "max": 60, "step": 2, "unit": "px", "default": 24 },
    { "type": "range", "id": "btn_radius", "label": "Button border radius",        "min": 0,  "max": 50, "step": 1, "unit": "px", "default": 50 },

    { "type": "header", "content": "── Spacing & Layout ─────────" },
    { "type": "range", "id": "padding_top",    "label": "Padding top",             "min": 0,  "max": 80, "step": 2, "unit": "px", "default": 20 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom",          "min": 0,  "max": 80, "step": 2, "unit": "px", "default": 20 },
    { "type": "range", "id": "padding_lr",     "label": "Padding left / right",    "min": 0,  "max": 80, "step": 2, "unit": "px", "default": 24 },
    { "type": "range", "id": "margin_top",     "label": "Margin top",              "min": 0,  "max": 80, "step": 4, "unit": "px", "default": 0 },
    { "type": "range", "id": "margin_bottom",  "label": "Margin bottom",           "min": 0,  "max": 80, "step": 4, "unit": "px", "default": 0 },
    { "type": "range", "id": "max_width",      "label": "Inner max-width",         "min": 400, "max": 1600, "step": 20, "unit": "px", "default": 1200 },
    { "type": "range", "id": "unit_gap",       "label": "Gap between H:M:S boxes", "min": 2,  "max": 32, "step": 1, "unit": "px", "default": 8 },
    { "type": "range", "id": "label_gap",      "label": "Gap: number box → label", "min": 0,  "max": 16, "step": 1, "unit": "px", "default": 5 },
    { "type": "range", "id": "inner_gap",      "label": "Gap between elements (vertical)",   "min": 0,  "max": 32, "step": 2, "unit": "px", "default": 12 },
    { "type": "range", "id": "inner_gap_h",    "label": "Gap between elements (horizontal)", "min": 0,  "max": 60, "step": 2, "unit": "px", "default": 24 },
    { "type": "range", "id": "sub_opacity",    "label": "Sub-message opacity",     "min": 20, "max": 100, "step": 5, "unit": "%", "default": 80 },
    {
      "type": "select",
      "id": "layout_align",
      "label": "Layout alignment",
      "options": [
        { "value": "center",        "label": "Center" },
        { "value": "flex-start",    "label": "Left" },
        { "value": "flex-end",      "label": "Right" },
        { "value": "space-between", "label": "Space between" }
      ],
      "default": "center"
    },
    { "type": "checkbox", "id": "hide_on_mobile", "label": "Hide on mobile", "default": false }
  ],
  "presets": [
    {
      "name": "Countdown Urgency Timer",
      "settings": {
        "headline": "⚡ Sale Ends In:",
        "sub_message": "Free shipping on all orders — today only",
        "reset_behavior": "loop24h",
        "bg_color": "#1a1a1a",
        "headline_color": "#ffffff",
        "highlight_color": "#E8920A",
        "sub_color": "#ffffff",
        "box_bg": "#2a2a2a",
        "box_border_color": "#E8920A",
        "num_color": "#E8920A",
        "colon_color": "#E8920A",
        "label_color": "#aaaaaa",
        "btn_bg": "#E8920A",
        "btn_text_color": "#ffffff",
        "btn_label": "Shop Now →",
        "show_labels": true
      }
    }
  ]
}
{% endschema %}
