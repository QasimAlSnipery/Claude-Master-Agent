{%- assign sid = 'sscount-' | append: section.id -%}

{%- comment %} Page visibility check {%- endcomment %}
{%- assign _show = false -%}
{%- case request.page_type -%}
  {%- when 'index' -%}{%- if section.settings.show_on_home -%}{%- assign _show = true -%}{%- endif -%}
  {%- when 'product' -%}{%- if section.settings.show_on_product -%}{%- assign _show = true -%}{%- endif -%}
  {%- when 'collection' -%}{%- if section.settings.show_on_collection -%}{%- assign _show = true -%}{%- endif -%}
  {%- when 'cart' -%}{%- if section.settings.show_on_cart -%}{%- assign _show = true -%}{%- endif -%}
  {%- when 'page' -%}{%- if section.settings.show_on_pages -%}{%- assign _show = true -%}{%- endif -%}
  {%- when 'blog', 'article' -%}{%- if section.settings.show_on_blog -%}{%- assign _show = true -%}{%- endif -%}
  {%- when 'search' -%}{%- if section.settings.show_on_search -%}{%- assign _show = true -%}{%- endif -%}
{%- endcase -%}

{%- if _show -%}

{%- comment %} Desktop layout helpers {%- endcomment %}
{%- assign dl  = section.settings.layout_desktop -%}
{%- assign dta = section.settings.text_align_desktop -%}
{%- if dta == 'left' -%}{%- assign dai = 'flex-start' -%}{%- elsif dta == 'right' -%}{%- assign dai = 'flex-end' -%}{%- else -%}{%- assign dai = 'center' -%}{%- endif -%}

{%- comment %} Mobile layout helpers {%- endcomment %}
{%- assign ml  = section.settings.layout_mob -%}
{%- assign mta = section.settings.text_align_mob -%}
{%- if mta == 'left' -%}{%- assign mai = 'flex-start' -%}{%- elsif mta == 'right' -%}{%- assign mai = 'flex-end' -%}{%- else -%}{%- assign mai = 'center' -%}{%- endif -%}

<style>
  /* ── Base ────────────────────────────────────────────── */
  #{{ sid }} {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px {{ section.settings.padding_lr }}px {{ section.settings.padding_bottom }}px;
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
  }
  #{{ sid }} .sscount__inner {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    display: flex;
    align-items: center;
  }

  /* ── Desktop Layout ──────────────────────────────────── */
  {%- if dl == 'inline' -%}
  #{{ sid }} .sscount__inner {
    flex-wrap: wrap;
    flex-direction: row;
    justify-content: {{ section.settings.layout_align }};
    gap: {{ section.settings.inner_gap }}px {{ section.settings.inner_gap_h }}px;
    text-align: {{ dta }};
  }
  #{{ sid }} .sscount__content { display: contents; }
  {%- elsif dl == 'timer-right' or dl == 'timer-left' -%}
  #{{ sid }} .sscount__inner {
    flex-wrap: nowrap;
    flex-direction: row;
    gap: {{ section.settings.inner_gap_h }}px;
  }
  #{{ sid }} .sscount__content {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: {{ dai }};
    gap: {{ section.settings.inner_gap }}px;
    text-align: {{ dta }};
    order: {%- if dl == 'timer-right' -%}1{%- else -%}2{%- endif -%};
  }
  #{{ sid }} .sscount__clock {
    flex-shrink: 0;
    order: {%- if dl == 'timer-right' -%}2{%- else -%}1{%- endif -%};
  }
  {%- elsif dl == 'timer-below' or dl == 'timer-above' -%}
  #{{ sid }} .sscount__inner {
    flex-direction: column;
    gap: {{ section.settings.inner_gap }}px;
  }
  #{{ sid }} .sscount__content {
    width: 100%;
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: {{ section.settings.layout_align }};
    align-items: center;
    gap: {{ section.settings.inner_gap }}px {{ section.settings.inner_gap_h }}px;
    text-align: {{ dta }};
    order: {%- if dl == 'timer-below' -%}1{%- else -%}2{%- endif -%};
  }
  #{{ sid }} .sscount__clock {
    order: {%- if dl == 'timer-below' -%}2{%- else -%}1{%- endif -%};
  }
  {%- endif -%}

  /* ── Elements ────────────────────────────────────────── */
  #{{ sid }} .sscount__headline {
    margin: 0;
    font-weight: 700;
    font-size: {{ section.settings.headline_size }}px;
    color: {{ section.settings.headline_color }};
    letter-spacing: 0.02em;
  }
  #{{ sid }} .sscount__hl {
    background: none;
    color: {{ section.settings.highlight_color }};
    -webkit-text-fill-color: {{ section.settings.highlight_color }};
    padding: 0;
  }
  #{{ sid }} .sscount__sub {
    margin: 0;
    font-size: {{ section.settings.sub_size }}px;
    color: {{ section.settings.sub_color }};
    opacity: {{ section.settings.sub_opacity | divided_by: 100.0 }};
  }
  #{{ sid }} .sscount__clock {
    display: flex;
    align-items: flex-start;
    gap: {{ section.settings.unit_gap }}px;
  }
  #{{ sid }} .sscount__unit {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: {{ section.settings.label_gap }}px;
  }
  #{{ sid }} .sscount__box {
    background-color: {{ section.settings.box_bg }};
    border: {{ section.settings.box_border_width }}px solid {{ section.settings.box_border_color }};
    border-radius: {{ section.settings.box_radius }}px;
    padding: {{ section.settings.box_pad_v }}px {{ section.settings.box_pad_h }}px;
    min-width: {{ section.settings.box_min_width }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  #{{ sid }} .sscount__num {
    font-size: {{ section.settings.num_size }}px;
    font-weight: 800;
    line-height: 1;
    color: {{ section.settings.num_color }};
    font-variant-numeric: tabular-nums;
    display: block;
    transition: transform 0.12s ease;
  }
  #{{ sid }} .sscount__num.flip { transform: scale(1.18); }
  #{{ sid }} .sscount__label {
    font-size: {{ section.settings.label_size }}px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: {{ section.settings.label_color }};
  }
  #{{ sid }} .sscount__colon {
    font-size: {{ section.settings.num_size }}px;
    font-weight: 800;
    color: {{ section.settings.colon_color }};
    line-height: 1;
    padding-top: {{ section.settings.box_pad_v }}px;
    opacity: {{ section.settings.colon_opacity | divided_by: 100.0 }};
    {%- if section.settings.show_labels -%}
    margin-bottom: calc({{ section.settings.label_size }}px + {{ section.settings.label_gap }}px + 2px);
    {%- endif -%}
  }
  #{{ sid }} .sscount__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ section.settings.btn_pad_v }}px {{ section.settings.btn_pad_h }}px;
    background-color: {{ section.settings.btn_bg }};
    color: {{ section.settings.btn_text_color }};
    font-weight: 700;
    font-size: {{ section.settings.btn_size }}px;
    text-decoration: none;
    border-radius: {{ section.settings.btn_radius }}px;
    white-space: nowrap;
    letter-spacing: 0.02em;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  #{{ sid }} .sscount__btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0,0,0,0.28);
  }

  /* ── Mobile ──────────────────────────────────────────── */
  {%- if section.settings.hide_on_mobile -%}
  @media(max-width:749px){ #{{ sid }}{ display:none!important; } }
  {%- else -%}
  @media(max-width:749px){
    #{{ sid }} {
      padding: {{ section.settings.padding_top_mob }}px {{ section.settings.padding_lr_mob }}px {{ section.settings.padding_bottom_mob }}px;
      margin-top: {{ section.settings.margin_top_mob }}px;
      margin-bottom: {{ section.settings.margin_bottom_mob }}px;
    }

    {%- if ml == 'inline' -%}
    #{{ sid }} .sscount__inner {
      flex-wrap: wrap;
      flex-direction: row;
      justify-content: {{ section.settings.layout_align_mob }};
      gap: {{ section.settings.inner_gap_mob }}px {{ section.settings.inner_gap_h_mob }}px;
      text-align: {{ mta }};
    }
    #{{ sid }} .sscount__content { display: contents; }
    #{{ sid }} .sscount__clock   { order: unset; }
    {%- elsif ml == 'timer-right' or ml == 'timer-left' -%}
    #{{ sid }} .sscount__inner {
      flex-wrap: nowrap;
      flex-direction: row;
      gap: {{ section.settings.inner_gap_h_mob }}px;
    }
    #{{ sid }} .sscount__content {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: {{ mai }};
      gap: {{ section.settings.inner_gap_mob }}px;
      text-align: {{ mta }};
      order: {%- if ml == 'timer-right' -%}1{%- else -%}2{%- endif -%};
    }
    #{{ sid }} .sscount__clock {
      flex-shrink: 0;
      order: {%- if ml == 'timer-right' -%}2{%- else -%}1{%- endif -%};
    }
    {%- elsif ml == 'timer-below' or ml == 'timer-above' -%}
    #{{ sid }} .sscount__inner {
      flex-direction: column;
      gap: {{ section.settings.inner_gap_mob }}px;
    }
    #{{ sid }} .sscount__content {
      width: 100%;
      display: flex;
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: {{ section.settings.layout_align_mob }};
      align-items: center;
      gap: {{ section.settings.inner_gap_mob }}px {{ section.settings.inner_gap_h_mob }}px;
      text-align: {{ mta }};
      order: {%- if ml == 'timer-below' -%}1{%- else -%}2{%- endif -%};
    }
    #{{ sid }} .sscount__clock {
      order: {%- if ml == 'timer-below' -%}2{%- else -%}1{%- endif -%};
    }
    {%- endif -%}

    #{{ sid }} .sscount__headline { font-size: {{ section.settings.headline_size_mob }}px; }
    #{{ sid }} .sscount__sub      { font-size: {{ section.settings.sub_size_mob }}px; }
    #{{ sid }} .sscount__clock    { gap: {{ section.settings.unit_gap_mob }}px; }
    #{{ sid }} .sscount__unit     { gap: {{ section.settings.label_gap_mob }}px; }
    #{{ sid }} .sscount__box {
      min-width: {{ section.settings.box_min_width_mob }}px;
      padding: {{ section.settings.box_pad_v_mob }}px {{ section.settings.box_pad_h_mob }}px;
      border-radius: {{ section.settings.box_radius_mob }}px;
    }
    #{{ sid }} .sscount__num   { font-size: {{ section.settings.num_size_mob }}px; }
    #{{ sid }} .sscount__colon {
      font-size: {{ section.settings.num_size_mob }}px;
      padding-top: {{ section.settings.box_pad_v_mob }}px;
      {%- if section.settings.show_labels -%}
      margin-bottom: calc({{ section.settings.label_size_mob }}px + {{ section.settings.label_gap_mob }}px + 2px);
      {%- endif -%}
    }
    #{{ sid }} .sscount__label { font-size: {{ section.settings.label_size_mob }}px; }
    #{{ sid }} .sscount__btn {
      font-size: {{ section.settings.btn_size_mob }}px;
      padding: {{ section.settings.btn_pad_v_mob }}px {{ section.settings.btn_pad_h_mob }}px;
      border-radius: {{ section.settings.btn_radius_mob }}px;
    }
  }
  {%- endif -%}

  /* ── Expired ─────────────────────────────────────────── */
  #{{ sid }}-expired {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px {{ section.settings.padding_lr }}px {{ section.settings.padding_bottom }}px;
    text-align: center;
    color: {{ section.settings.headline_color }};
    font-size: {{ section.settings.headline_size }}px;
    font-weight: 700;
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
  }
</style>

<div id="{{ sid }}" role="region" aria-label="Sale countdown timer">
  <div class="sscount__inner">

    <div class="sscount__content">
      {%- if section.settings.headline != blank -%}
        <p class="sscount__headline">
          {%- if section.settings.headline_highlight != blank -%}
            {{- section.settings.headline | split: section.settings.headline_highlight | first -}}<mark class="sscount__hl">{{- section.settings.headline_highlight -}}</mark>{{- section.settings.headline | split: section.settings.headline_highlight | last -}}
          {%- else -%}
            {{- section.settings.headline -}}
          {%- endif -%}
        </p>
      {%- endif -%}
      {%- if section.settings.sub_message != blank -%}
        <p class="sscount__sub">{{ section.settings.sub_message }}</p>
      {%- endif -%}
      {%- if section.settings.btn_label != blank -%}
        <a href="{{ section.settings.btn_link | default: '#' }}" class="sscount__btn">
          {{- section.settings.btn_label -}}
        </a>
      {%- endif -%}
    </div>

    <div class="sscount__clock" aria-live="polite">

      {%- if section.settings.show_days -%}
      <div class="sscount__unit">
        <div class="sscount__box">
          <span class="sscount__num" id="{{ sid }}-days">00</span>
        </div>
        {%- if section.settings.show_labels -%}
          <span class="sscount__label">{{ section.settings.label_days | default: 'DAYS' }}</span>
        {%- endif -%}
      </div>
      <span class="sscount__colon" aria-hidden="true">:</span>
      {%- endif -%}

      {%- unless section.settings.hide_hours -%}
      <div class="sscount__unit">
        <div class="sscount__box">
          <span class="sscount__num" id="{{ sid }}-hours">00</span>
        </div>
        {%- if section.settings.show_labels -%}
          <span class="sscount__label">{{ section.settings.label_hours | default: 'HRS' }}</span>
        {%- endif -%}
      </div>
      <span class="sscount__colon" aria-hidden="true">:</span>
      {%- endunless -%}

      <div class="sscount__unit">
        <div class="sscount__box">
          <span class="sscount__num" id="{{ sid }}-minutes">00</span>
        </div>
        {%- if section.settings.show_labels -%}
          <span class="sscount__label">{{ section.settings.label_mins | default: 'MINS' }}</span>
        {%- endif -%}
      </div>

      {%- unless section.settings.hide_seconds -%}
      <span class="sscount__colon" aria-hidden="true">:</span>
      <div class="sscount__unit">
        <div class="sscount__box">
          <span class="sscount__num" id="{{ sid }}-seconds">00</span>
        </div>
        {%- if section.settings.show_labels -%}
          <span class="sscount__label">{{ section.settings.label_secs | default: 'SECS' }}</span>
        {%- endif -%}
      </div>
      {%- endunless -%}

    </div>

  </div>
</div>

<div id="{{ sid }}-expired" style="display:none;" aria-live="polite">
  {{ section.settings.expired_message | default: 'This offer has ended.' }}
</div>

<script>
(function(){
  var sid      = {{ sid | json }};
  var endStr   = {{ section.settings.end_date | json }};
  var mode     = {{ section.settings.reset_behavior | json }};
  var hideHrs  = {{ section.settings.hide_hours  | json }};
  var hideSecs = {{ section.settings.hide_seconds | json }};
  var showDays = {{ section.settings.show_days   | json }};

  var wrap    = document.getElementById(sid);
  var expWrap = document.getElementById(sid + '-expired');
  var dEl     = document.getElementById(sid + '-days');
  var hEl     = document.getElementById(sid + '-hours');
  var mEl     = document.getElementById(sid + '-minutes');
  var sEl     = document.getElementById(sid + '-seconds');
  if (!wrap) return;

  function getEnd() {
    if (mode === 'midnight') {
      var d = new Date();
      d.setHours(24, 0, 0, 0);
      return d.getTime();
    }
    if (mode === 'loop24h') {
      var stored;
      try { stored = localStorage.getItem('sscount_end_' + sid); } catch(e){}
      var now = Date.now();
      if (!stored || parseInt(stored) <= now) {
        var t = now + 86400000;
        try { localStorage.setItem('sscount_end_' + sid, String(t)); } catch(e){}
        return t;
      }
      return parseInt(stored);
    }
    if (endStr) return new Date(endStr).getTime();
    return Date.now() + 86400000;
  }

  var endTime = getEnd();
  function pad(n){ return n < 10 ? '0' + n : '' + n; }

  function flip(el, val){
    if (!el || el.textContent === val) return;
    el.classList.remove('flip');
    void el.offsetWidth;
    el.textContent = val;
    el.classList.add('flip');
    setTimeout(function(){ el.classList.remove('flip'); }, 130);
  }

  function tick(){
    var diff = endTime - Date.now();
    if (diff <= 0){
      if (mode === 'loop24h'){
        endTime = Date.now() + 86400000;
        try { localStorage.setItem('sscount_end_' + sid, String(endTime)); } catch(e){}
        diff = endTime - Date.now();
      } else if (mode === 'midnight'){
        endTime = getEnd();
        diff = endTime - Date.now();
      } else if (mode === 'hide'){
        wrap.style.display = 'none'; return;
      } else {
        wrap.style.display = 'none';
        if (expWrap) expWrap.style.display = ''; return;
      }
    }
    var total = Math.floor(diff / 1000);
    var days  = Math.floor(total / 86400);
    var h     = Math.floor((total % 86400) / 3600);
    var m     = Math.floor((total % 3600) / 60);
    var s     = total % 60;

    if (showDays) flip(dEl, pad(days));
    if (!hideHrs) {
      flip(hEl, pad(h));
    } else if (!showDays) {
      m = Math.floor(total / 60);
    }
    flip(mEl, pad(m));
    if (!hideSecs) flip(sEl, pad(s));
  }

  tick();
  setInterval(tick, 1000);
})();
</script>

{%- endif -%}

{% schema %}
{
  "name": "Countdown Urgency Timer",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "header", "content": "── Page Visibility ──────────" },
    { "type": "paragraph", "content": "Tick the page types where this section should appear. Unticked = hidden on that page type." },
    { "type": "checkbox", "id": "show_on_product",   "label": "Product pages",    "default": true },
    { "type": "checkbox", "id": "show_on_home",       "label": "Home page",        "default": false },
    { "type": "checkbox", "id": "show_on_collection", "label": "Collection pages", "default": false },
    { "type": "checkbox", "id": "show_on_cart",       "label": "Cart page",        "default": false },
    { "type": "checkbox", "id": "show_on_pages",      "label": "Standard pages",   "default": false },
    { "type": "checkbox", "id": "show_on_blog",       "label": "Blog & articles",  "default": false },
    { "type": "checkbox", "id": "show_on_search",     "label": "Search results",   "default": false },

    { "type": "header", "content": "── Content ──────────────────" },
    { "type": "text", "id": "headline", "label": "Headline", "default": "⚡ Sale Ends In:" },
    { "type": "text", "id": "headline_highlight", "label": "Highlight text", "info": "Exact word(s) from headline to colour differently. Leave blank to skip." },
    { "type": "text", "id": "sub_message", "label": "Sub-message", "default": "Free shipping on all orders — today only" },
    { "type": "text", "id": "end_date", "label": "Sale end date & time", "info": "Format: YYYY-MM-DDTHH:MM:SS e.g. 2026-06-30T23:59:00 — ignored when mode is Loop or Midnight", "default": "2026-12-31T23:59:00" },
    {
      "type": "select", "id": "reset_behavior", "label": "When timer hits zero",
      "options": [
        { "value": "loop24h",  "label": "Loop — reset to 24 hours from first visit" },
        { "value": "midnight", "label": "Reset at midnight (customer's local time)" },
        { "value": "message",  "label": "Show expired message" },
        { "value": "hide",     "label": "Hide section" }
      ],
      "default": "loop24h"
    },
    { "type": "text", "id": "expired_message", "label": "Expired message", "default": "This offer has ended." },

    { "type": "header", "content": "── CTA Button ───────────────" },
    { "type": "text", "id": "btn_label", "label": "Button label", "default": "Shop Now →" },
    { "type": "url",  "id": "btn_link",  "label": "Button link" },

    { "type": "header", "content": "── Timer Units ──────────────" },
    { "type": "checkbox", "id": "show_labels",  "label": "Show labels below numbers", "default": true },
    { "type": "checkbox", "id": "show_days",    "label": "Show DAYS unit", "default": false },
    { "type": "checkbox", "id": "hide_hours",   "label": "Hide HOURS unit", "default": false },
    { "type": "checkbox", "id": "hide_seconds", "label": "Hide SECONDS unit", "default": false },
    { "type": "text", "id": "label_days",  "label": "Days label text",    "default": "DAYS" },
    { "type": "text", "id": "label_hours", "label": "Hours label text",   "default": "HRS" },
    { "type": "text", "id": "label_mins",  "label": "Minutes label text", "default": "MINS" },
    { "type": "text", "id": "label_secs",  "label": "Seconds label text", "default": "SECS" },

    { "type": "header", "content": "── Colors (shared) ──────────" },
    { "type": "color", "id": "bg_color",         "label": "Section background",           "default": "#1a1a1a" },
    { "type": "color", "id": "headline_color",   "label": "Headline color",                "default": "#ffffff" },
    { "type": "color", "id": "highlight_color",  "label": "Highlight color",               "default": "#E8920A" },
    { "type": "color", "id": "sub_color",        "label": "Sub-message color",             "default": "#ffffff" },
    { "type": "color", "id": "box_bg",           "label": "Number box background",         "default": "#2a2a2a" },
    { "type": "color", "id": "box_border_color", "label": "Number box border color",       "default": "#E8920A" },
    { "type": "color", "id": "num_color",        "label": "Number color",                  "default": "#E8920A" },
    { "type": "color", "id": "colon_color",      "label": "Colon color",                   "default": "#E8920A" },
    { "type": "color", "id": "label_color",      "label": "Label color (DAYS/HRS/MINS/SECS)", "default": "#aaaaaa" },
    { "type": "color", "id": "btn_bg",           "label": "Button background",             "default": "#E8920A" },
    { "type": "color", "id": "btn_text_color",   "label": "Button text color",             "default": "#ffffff" },

    { "type": "header", "content": "━━ DESKTOP ━━━━━━━━━━━━━━━━━━" },

    { "type": "header", "content": "Layout & Alignment — Desktop" },
    {
      "type": "select", "id": "layout_desktop", "label": "Timer position",
      "options": [
        { "value": "inline",      "label": "Inline — all in one row" },
        { "value": "timer-right", "label": "Text left · Timer right" },
        { "value": "timer-left",  "label": "Timer left · Text right" },
        { "value": "timer-below", "label": "Text above · Timer below" },
        { "value": "timer-above", "label": "Timer above · Text below" }
      ],
      "default": "inline"
    },
    {
      "type": "select", "id": "text_align_desktop", "label": "Text & button alignment",
      "info": "Applies to text group in all layouts except Inline",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right" }
      ],
