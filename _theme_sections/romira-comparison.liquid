{%- style -%}
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.background_color }} !important;
    overflow: clip;
    max-width: {{ section.settings.section_max_width }}px;
    width: 100%;
    margin-left: auto;
    margin-right: auto;
    padding-top: 0 !important;
    padding-bottom: 0 !important;
  }
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      max-width: {{ section.settings.section_max_width_mobile }}px;
    }
  }
  .romira-comparison-{{ section.id }} {
    padding-top: {{ section.settings.mobile_padding_top }}px;
    padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    background-color: {{ section.settings.background_color }} !important;
    overflow: clip;
  }
  @media screen and (min-width: 750px) {
    .romira-comparison-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  .romira-comparison-{{ section.id }} .rc-inner {
    max-width: {{ section.settings.content_width }}px;
    margin: 0 auto;
    padding: 0 {{ section.settings.horizontal_padding_mobile }}px;
    box-sizing: border-box;
  }
  @media screen and (min-width: 750px) {
    .romira-comparison-{{ section.id }} .rc-inner {
      padding: 0 {{ section.settings.horizontal_padding }}px;
    }
  }
  .romira-comparison-{{ section.id }} .rc-header {
    text-align: {{ section.settings.heading_alignment }};
    margin-bottom: 32px;
    padding: 0 4px;
  }
  .romira-comparison-{{ section.id }} .rc-heading {
    font-size: {{ section.settings.heading_size_mobile }}px;
    color: {{ section.settings.heading_color }};
    margin: 0 0 10px;
    line-height: 1.2;
    word-wrap: break-word;
  }
  @media screen and (min-width: 750px) {
    .romira-comparison-{{ section.id }} .rc-heading {
      font-size: {{ section.settings.heading_size }}px;
    }
  }
  .romira-comparison-{{ section.id }} .rc-subheading {
    color: {{ section.settings.subheading_color }};
    font-size: 15px;
    margin: 0;
    word-wrap: break-word;
  }
  /* Scroll wrapper for mobile */
  .romira-comparison-{{ section.id }} .rc-scroll {
    overflow-x: auto;
    border-radius: {{ section.settings.table_radius }}px;
    border: 1px solid {{ section.settings.border_color }};
  }
  /* Table */
  .romira-comparison-{{ section.id }} table {
    width: 100%;
    min-width: 340px;
    border-collapse: collapse;
  }
  /* Column widths */
  .romira-comparison-{{ section.id }} .col-romira { width: {{ section.settings.brand_col_width }}%; }
  .romira-comparison-{{ section.id }} .col-feature { width: {{ section.settings.feature_col_width }}%; }
  .romira-comparison-{{ section.id }} .col-others  { width: {{ section.settings.brand_col_width }}%; }
  /* Header row with images */
  .romira-comparison-{{ section.id }} .rc-header-row th {
    padding: {{ section.settings.header_padding }}px {{ section.settings.col_padding_mobile }}px;
    text-align: center;
    vertical-align: middle;
    border-bottom: 2px solid {{ section.settings.border_color }};
  }
  @media screen and (min-width: 750px) {
    .romira-comparison-{{ section.id }} .rc-header-row th {
      padding: {{ section.settings.header_padding }}px {{ section.settings.col_padding }}px;
    }
  }
  .romira-comparison-{{ section.id }} .rc-header-row .th-romira {
    background: {{ section.settings.romira_header_bg }};
    color: {{ section.settings.romira_header_color }};
    border-right: 1px solid {{ section.settings.border_color }};
  }
  .romira-comparison-{{ section.id }} .rc-header-row .th-feature {
    background: {{ section.settings.feature_header_bg }};
    color: {{ section.settings.feature_header_color }};
    text-align: {{ section.settings.feature_text_align }};
  }
  .romira-comparison-{{ section.id }} .rc-header-row .th-others {
    background: {{ section.settings.others_header_bg }};
    color: {{ section.settings.others_header_color }};
    border-left: 1px solid {{ section.settings.border_color }};
  }
  .romira-comparison-{{ section.id }} .rc-brand-img {
    width: {{ section.settings.brand_img_size_mobile }}px;
    height: {{ section.settings.brand_img_size_mobile }}px;
    object-fit: contain;
    display: block;
    margin: 0 auto {{ section.settings.brand_img_gap }}px;
    border-radius: {{ section.settings.brand_img_radius }}px;
  }
  @media screen and (min-width: 750px) {
    .romira-comparison-{{ section.id }} .rc-brand-img {
      width: {{ section.settings.brand_img_size }}px;
      height: {{ section.settings.brand_img_size }}px;
    }
  }
  .romira-comparison-{{ section.id }} .rc-brand-name {
    font-size: {{ section.settings.brand_name_size_mobile }}px !important;
    font-weight: {{ section.settings.brand_name_weight }} !important;
    line-height: 1.2;
    margin: 0;
    padding: 0;
    display: block;
    word-wrap: break-word;
  }
  @media screen and (min-width: 750px) {
    .romira-comparison-{{ section.id }} .rc-brand-name {
      font-size: {{ section.settings.brand_name_size }}px !important;
    }
  }
  .romira-comparison-{{ section.id }} .rc-feature-header {
    font-size: {{ section.settings.feature_header_size_mobile }}px !important;
    font-weight: {{ section.settings.feature_header_weight }} !important;
    color: {{ section.settings.feature_header_color }} !important;
    line-height: 1.2;
    margin: 0;
    padding: 0;
    display: block;
    word-wrap: break-word;
  }
  @media screen and (min-width: 750px) {
    .romira-comparison-{{ section.id }} .rc-feature-header {
      font-size: {{ section.settings.feature_header_size }}px !important;
    }
  }
  /* Data rows */
  .romira-comparison-{{ section.id }} .rc-row td {
    padding: {{ section.settings.row_padding_mobile }}px {{ section.settings.col_padding_mobile }}px;
    border-bottom: 1px solid {{ section.settings.border_color }};
    vertical-align: middle;
    line-height: 1.4;
  }
  @media screen and (min-width: 750px) {
    .romira-comparison-{{ section.id }} .rc-row td {
      padding: {{ section.settings.row_padding }}px {{ section.settings.col_padding }}px;
    }
  }
  .romira-comparison-{{ section.id }} .rc-row:last-child td { border-bottom: none; }
  .romira-comparison-{{ section.id }} .rc-row .td-romira {
    background: {{ section.settings.romira_cell_bg }};
    text-align: center;
    border-right: 1px solid {{ section.settings.border_color }};
  }
  .romira-comparison-{{ section.id }} .rc-row .td-feature {
    background: {{ section.settings.feature_cell_bg }};
    text-align: {{ section.settings.feature_text_align }};
    font-size: {{ section.settings.feature_text_size_mobile }}px;
    font-weight: {{ section.settings.feature_text_weight }};
    color: {{ section.settings.feature_text_color }};
    word-wrap: break-word;
  }
  @media screen and (min-width: 750px) {
    .romira-comparison-{{ section.id }} .rc-row .td-feature {
      font-size: {{ section.settings.feature_text_size }}px;
    }
  }
  .romira-comparison-{{ section.id }} .rc-row .td-others {
    background: {{ section.settings.others_cell_bg }};
    text-align: center;
    border-left: 1px solid {{ section.settings.border_color }};
  }
  /* Check / Cross icons */
  .romira-comparison-{{ section.id }} .rc-check,
  .romira-comparison-{{ section.id }} .rc-cross {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    border-radius: 50%;
    font-size: {{ section.settings.icon_font_size }}px;
    font-weight: 700;
    line-height: 1;
  }
  .romira-comparison-{{ section.id }} .rc-check {
    background: {{ section.settings.check_bg }};
    color: {{ section.settings.check_color }};
  }
  .romira-comparison-{{ section.id }} .rc-cross {
    background: {{ section.settings.cross_bg }};
    color: {{ section.settings.cross_color }};
  }
  /* Custom text below icon */
  .romira-comparison-{{ section.id }} .rc-icon-label {
    display: block;
    font-size: {{ section.settings.icon_label_size }}px;
    color: {{ section.settings.icon_label_color }};
    margin-top: 4px;
    word-wrap: break-word;
  }
  /* Animation */
  .romira-comparison-{{ section.id }} .rc-scroll {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .romira-comparison-{{ section.id }} .rc-scroll.rc-visible {
    opacity: 1;
    transform: translateY(0);
  }
{%- endstyle -%}

<div class="romira-comparison-{{ section.id }}">
  <div class="rc-inner">
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="rc-header">
        {%- if section.settings.heading != blank -%}
          <{{ section.settings.heading_tag }} class="rc-heading">{{ section.settings.heading }}</{{ section.settings.heading_tag }}>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="rc-subheading">{{ section.settings.subheading }}</span>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="rc-scroll" id="rc-table-{{ section.id }}">
      <table>
        <colgroup>
          <col class="col-romira">
          <col class="col-feature">
          <col class="col-others">
        </colgroup>
        <thead>
          <tr class="rc-header-row">
            <th class="th-romira">
              {%- if section.settings.romira_image != blank -%}
                {{ section.settings.romira_image | image_url: width: 200 | image_tag: class: 'rc-brand-img', loading: 'lazy' }}
              {%- endif -%}
              <span class="rc-brand-name">{{ section.settings.romira_col_label }}</span>
            </th>
            <th class="th-feature"><span class="rc-feature-header">{{ section.settings.feature_col_label }}</span></th>
            <th class="th-others">
              {%- if section.settings.others_image != blank -%}
                {{ section.settings.others_image | image_url: width: 200 | image_tag: class: 'rc-brand-img', loading: 'lazy' }}
              {%- endif -%}
              <span class="rc-brand-name">{{ section.settings.others_col_label }}</span>
            </th>
          </tr>
        </thead>
        <tbody>
          {%- for block in section.blocks -%}
            <tr class="rc-row" {{ block.shopify_attributes }}>
              <td class="td-romira">
                <span class="rc-check">{{ section.settings.check_symbol }}</span>
                {%- if block.settings.romira_label != blank -%}
                  <span class="rc-icon-label">{{ block.settings.romira_label }}</span>
                {%- endif -%}
              </td>
              <td class="td-feature">{{ block.settings.feature }}</td>
              <td class="td-others">
                {%- if block.settings.others_has_check -%}
                  <span class="rc-check">{{ section.settings.check_symbol }}</span>
                {%- else -%}
                  <span class="rc-cross">{{ section.settings.cross_symbol }}</span>
                {%- endif -%}
                {%- if block.settings.others_label != blank -%}
                  <span class="rc-icon-label">{{ block.settings.others_label }}</span>
                {%- endif -%}
              </td>
            </tr>
          {%- endfor -%}
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
(function() {
  var el = document.getElementById('rc-table-{{ section.id }}');
  if (!el) return;
  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        el.classList.add('rc-visible');
        observer.unobserve(el);
      }
    });
  }, { threshold: 0.1 });
  observer.observe(el);
})();
</script>

{% schema %}
