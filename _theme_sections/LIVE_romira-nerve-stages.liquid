{%- style -%}
  .romira-stages-{{ section.id }} {
    padding-top: {{ section.settings.mobile_padding_top }}px;
    padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    background-color: {{ section.settings.background_color }};
    overflow-x: hidden;
  }
  @media screen and (min-width: 750px) {
    .romira-stages-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  .romira-stages-{{ section.id }} .rs-inner {
    max-width: {{ section.settings.content_width }}px;
    margin: 0 auto;
    padding: 0 {{ section.settings.horizontal_padding_mobile }}px;
    box-sizing: border-box;
  }
  @media screen and (min-width: 750px) {
    .romira-stages-{{ section.id }} .rs-inner {
      padding: 0 {{ section.settings.horizontal_padding }}px;
    }
  }
  .romira-stages-{{ section.id }} .rs-header {
    text-align: {{ section.settings.heading_alignment }};
    margin-bottom: 40px;
    padding: 0 4px;
  }
  .romira-stages-{{ section.id }} .rs-heading {
    font-size: {{ section.settings.heading_size_mobile }}px;
    color: {{ section.settings.heading_color }};
    margin: 0 0 12px;
    line-height: 1.2;
    word-wrap: break-word;
  }
  @media screen and (min-width: 750px) {
    .romira-stages-{{ section.id }} .rs-heading {
      font-size: {{ section.settings.heading_size }}px;
    }
  }
  .romira-stages-{{ section.id }} .rs-subheading {
    font-size: 15px;
    color: {{ section.settings.subheading_color }};
    margin: 0 auto;
    max-width: 700px;
    line-height: 1.6;
    word-wrap: break-word;
  }
  @media screen and (min-width: 750px) {
    .romira-stages-{{ section.id }} .rs-subheading {
      font-size: 16px;
    }
  }
  /* Each stage: image on left, text on right */
  .romira-stages-{{ section.id }} .rs-stages-list {
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.block_gap_mobile }}px;
  }
  @media screen and (min-width: 750px) {
    .romira-stages-{{ section.id }} .rs-stages-list {
      gap: {{ section.settings.block_gap }}px;
    }
  }
  .romira-stages-{{ section.id }} .rs-stage {
    display: flex;
    flex-direction: column;
    background: {{ section.settings.block_bg_color }};
    border-radius: {{ section.settings.block_border_radius }}px;
    overflow: hidden;
    border: 1px solid {{ section.settings.block_border_color }};
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .romira-stages-{{ section.id }} .rs-stage.rs-visible {
    opacity: 1;
    transform: translateY(0);
  }
  @media screen and (min-width: 750px) {
    .romira-stages-{{ section.id }} .rs-stage {
      flex-direction: row;
      align-items: stretch;
    }
    .romira-stages-{{ section.id }} .rs-stage.rs-image-right {
      flex-direction: row-reverse;
    }
  }
  /* Image side */
  .romira-stages-{{ section.id }} .rs-stage-image {
    width: 100%;
    flex-shrink: 0;
    overflow: hidden;
  }
  @media screen and (min-width: 750px) {
    .romira-stages-{{ section.id }} .rs-stage-image {
      width: {{ section.settings.image_width_desktop }}%;
    }
  }
  .romira-stages-{{ section.id }} .rs-stage-image img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    aspect-ratio: {{ section.settings.mobile_image_ratio }};
  }
  @media screen and (min-width: 750px) {
    .romira-stages-{{ section.id }} .rs-stage-image img {
      aspect-ratio: {{ section.settings.desktop_image_ratio }};
    }
  }
  .romira-stages-{{ section.id }} .rs-stage-placeholder {
    width: 100%;
    aspect-ratio: {{ section.settings.mobile_image_ratio }};
    background: #e8e8e8;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #999;
    font-size: 13px;
  }
  @media screen and (min-width: 750px) {
    .romira-stages-{{ section.id }} .rs-stage-placeholder {
      aspect-ratio: {{ section.settings.desktop_image_ratio }};
      height: 100%;
    }
  }
  /* Text side */
  .romira-stages-{{ section.id }} .rs-stage-content {
    padding: {{ section.settings.content_padding_mobile }}px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    flex: 1;
    min-width: 0;
    box-sizing: border-box;
  }
  @media screen and (min-width: 750px) {
    .romira-stages-{{ section.id }} .rs-stage-content {
      padding: {{ section.settings.content_padding }}px;
    }
  }
  .romira-stages-{{ section.id }} .rs-stage-label {
    font-size: {{ section.settings.label_size }}px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: {{ section.settings.stage_label_color }};
    margin: 0 0 8px;
  }
  .romira-stages-{{ section.id }} .rs-stage-heading {
    font-size: {{ section.settings.block_heading_size_mobile }}px;
    color: {{ section.settings.block_heading_color }};
    margin: 0 0 12px;
    line-height: 1.3;
    word-wrap: break-word;
  }
  @media screen and (min-width: 750px) {
    .romira-stages-{{ section.id }} .rs-stage-heading {
      font-size: {{ section.settings.block_heading_size }}px;
    }
  }
  .romira-stages-{{ section.id }} .rs-stage-text {
    font-size: {{ section.settings.block_text_size_mobile }}px;
    color: {{ section.settings.block_text_color }};
    line-height: 1.7;
    margin: 0;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }
  @media screen and (min-width: 750px) {
    .romira-stages-{{ section.id }} .rs-stage-text {
      font-size: {{ section.settings.block_text_size }}px;
    }
  }
  .romira-stages-{{ section.id }} .rs-stage-text p { margin: 0 0 8px; }
  .romira-stages-{{ section.id }} .rs-stage-text p:last-child { margin: 0; }
{%- endstyle -%}

<div class="romira-stages-{{ section.id }}">
  <div class="rs-inner">
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="rs-header">
        {%- if section.settings.heading != blank -%}
          <{{ section.settings.heading_tag }} class="rs-heading">{{ section.settings.heading }}</{{ section.settings.heading_tag }}>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="rs-subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="rs-stages-list" id="rs-list-{{ section.id }}">
      {%- for block in section.blocks -%}
        <div class="rs-stage{% if section.settings.alternate_sides and forloop.index0 != 0 and forloop.index0 != 2 %} rs-image-right{% endif %}" {{ block.shopify_attributes }} data-delay="{{ forloop.index0 | times: 200 }}">
          <div class="rs-stage-image">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', style: 'width:100%;height:100%;object-fit:cover;display:block;' }}
            {%- else -%}
              <div class="rs-stage-placeholder">Add image in theme editor</div>
            {%- endif -%}
          </div>
          <div class="rs-stage-content">
            {%- if block.settings.stage_label != blank -%}
              <p class="rs-stage-label">{{ block.settings.stage_label }}</p>
            {%- endif -%}
            {%- if block.settings.heading != blank -%}
              <h3 class="rs-stage-heading">{{ block.settings.heading }}</h3>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <div class="rs-stage-text">{{ block.settings.text }}</div>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

<script>
(function() {
  var list = document.getElementById('rs-list-{{ section.id }}');
  if (!list) return;
  var stages = list.querySelectorAll('.rs-stage');
  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        var el = entry.target;
        var delay = parseInt(el.getAttribute('data-delay') || 0);
        setTimeout(function() { el.classList.add('rs-visible'); }, delay);
        observer.unobserve(el);
      }
    });
  }, { threshold: 0.1 });
  stages.forEach(function(s) { observer.observe(s); });
})();
</script>

{% schema %}
{
  "name": "Romira — Nerve Stages",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "The 3 Stages of Nerve Breakdown" },
    { "type": "select", "id": "heading_tag", "label": "Heading tag", "options": [{"value":"h1","label":"H1"},{"value":"h2","label":"H2"},{"value":"h3","label":"H3"}], "default": "h2" },
    { "type": "range", "id": "heading_size", "min": 20, "max": 60, "step": 2, "unit": "px", "label": "Heading size (desktop)", "default": 36 },
    { "type": "range", "id": "heading_size_mobile", "min": 16, "max": 40, "step": 1, "unit": "px", "label": "Heading size (mobile)", "default": 24 },
    { "type": "select", "id": "heading_alignment", "label": "Heading alignment", "options": [{"value":"left","label":"Left"},{"value":"center","label":"Center"},{"value":"right","label":"Right"}], "default": "center" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Most nerve discomfort builds through predictable stages. Recognising yours is the first step." },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#1a1a1a" },
    { "type": "color", "id": "subheading_color", "label": "Subheading color", "default": "#555555" },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#ffffff" },
    { "type": "color", "id": "block_bg_color", "label": "Card background", "default": "#ffffff" },
    { "type": "color", "id": "block_border_color", "label": "Card border color", "default": "#e8e8e8" },
    { "type": "range", "id": "block_border_radius", "min": 0, "max": 24, "step": 2, "unit": "px", "label": "Card border radius", "default": 12 },
    { "type": "checkbox", "id": "alternate_sides", "label": "Alternate image sides (2nd card flips)", "default": false },
    { "type": "header", "content": "Image" },
    { "type": "range", "id": "image_width_desktop", "min": 30, "max": 60, "step": 5, "unit": "%", "label": "Image width on desktop", "default": 45 },
    { "type": "text", "id": "desktop_image_ratio", "label": "Desktop image ratio (e.g. 4/3, 1/1, 16/9)", "default": "4/3" },
    { "type": "text", "id": "mobile_image_ratio", "label": "Mobile image ratio (e.g. 4/3, 16/9)", "default": "16/9" },
    { "type": "header", "content": "Typography" },
    { "type": "color", "id": "stage_label_color", "label": "Stage label color", "default": "#264165" },
    { "type": "range", "id": "label_size", "min": 9, "max": 14, "step": 1, "unit": "px", "label": "Stage label size", "default": 11 },
    { "type": "color", "id": "block_heading_color", "label": "Card heading color", "default": "#1a1a1a" },
    { "type": "range", "id": "block_heading_size", "min": 16, "max": 36, "step": 1, "unit": "px", "label": "Card heading (desktop)", "default": 22 },
    { "type": "range", "id": "block_heading_size_mobile", "min": 16, "max": 30, "step": 1, "unit": "px", "label": "Card heading (mobile)", "default": 19 },
    { "type": "color", "id": "block_text_color", "label": "Card text color", "default": "#444444" },
    { "type": "range", "id": "block_text_size", "min": 13, "max": 20, "step": 1, "unit": "px", "label": "Card text size (desktop)", "default": 16 },
    { "type": "range", "id": "block_text_size_mobile", "min": 13, "max": 18, "step": 1, "unit": "px", "label": "Card text size (mobile)", "default": 14 },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "block_gap", "min": 8, "max": 60, "step": 4, "unit": "px", "label": "Gap between stages (desktop)", "default": 24 },
    { "type": "range", "id": "block_gap_mobile", "min": 8, "max": 40, "step": 4, "unit": "px", "label": "Gap between stages (mobile)", "default": 16 },
    { "type": "range", "id": "content_padding", "min": 16, "max": 60, "step": 4, "unit": "px", "label": "Content padding (desktop)", "default": 40 },
    { "type": "range", "id": "content_padding_mobile", "min": 12, "max": 40, "step": 4, "unit": "px", "label": "Content padding (mobile)", "default": 20 },
    { "type": "range", "id": "content_width", "min": 600, "max": 1400, "step": 20, "unit": "px", "label": "Max content width", "default": 1100 },
    { "type": "range", "id": "horizontal_padding", "min": 0, "max": 80, "step": 4, "unit": "px", "label": "Horizontal padding (desktop)", "default": 20 },
    { "type": "range", "id": "horizontal_padding_mobile", "min": 8, "max": 40, "step": 4, "unit": "px", "label": "Horizontal padding (mobile)", "default": 16 },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding top (desktop)", "default": 60 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding bottom (desktop)", "default": 60 },
    { "type": "range", "id": "mobile_padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding top (mobile)", "default": 36 },
    { "type": "range", "id": "mobile_padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding bottom (mobile)", "default": 36 }
  ],
  "blocks": [
    {
      "type": "stage",
      "name": "Stage",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Stage image" },
        { "type": "text", "id": "stage_label", "label": "Stage label", "default": "STAGE 1" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Early Warning Signs" },
        { "type": "richtext", "id": "text", "label": "Description", "default": "<p>Occasional tingling or numbness in hands and feet. Usually worse at night. Most people assume it will pass — and ignore it for months.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Romira — Nerve Stages",
      "blocks": [
        { "type": "stage", "settings": { "stage_label": "STAGE 1", "heading": "Early Warning Signs", "text": "<p>Occasional tingling or numbness in hands and feet. Usually worse at night. Most people assume it will pass — and ignore it for months.</p>" } },
        { "type": "stage", "settings": { "stage_label": "STAGE 2", "heading": "The Discomfort Sets In", "text": "<p>Burning, electric shocks, and pins-and-needles become daily. Sleep suffers. Simple tasks — walking, holding objects — become uncomfortable.</p>" } },
        { "type": "stage", "settings": { "stage_label": "STAGE 3", "heading": "Your World Gets Smaller", "text": "<p>Chronic nerve discomfort limits mobility, disrupts sleep, and affects mood. Many have tried multiple approaches with little lasting relief. This is where R-ALA works differently.</p>" } }
      ]
    }
  ]
}
{% endschema %}
