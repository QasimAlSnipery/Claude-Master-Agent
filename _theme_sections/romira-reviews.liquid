{%- style -%}
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.section_bg }} !important;
    overflow: hidden;
    max-width: {{ section.settings.section_max_width }}px;
    width: 100%;
    margin-left: auto;
    margin-right: auto;
    padding-top: 0 !important;
    padding-bottom: 0 !important;
  }
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      max-width: {{ section.settings.section_max_width_mobile }}px;
    }
  }

  .rrev-{{ section.id }} {
    background-color: {{ section.settings.section_bg }} !important;
    padding-top: {{ section.settings.mobile_padding_top }}px;
    padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
  }
  @media (min-width: 750px) {
    .rrev-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* ── Header ── */
  .rrev-{{ section.id }} .rrev-header {
    padding: 0 {{ section.settings.header_h_pad_mobile }}px {{ section.settings.header_gap_mobile }}px;
    box-sizing: border-box;
  }
  @media (min-width: 750px) {
    .rrev-{{ section.id }} .rrev-header {
      padding: 0 {{ section.settings.header_h_pad }}px {{ section.settings.header_gap }}px;
    }
  }

  .rrev-{{ section.id }} .rrev-heading {
    font-size: {{ section.settings.heading_size_mobile }}px !important;
    font-weight: {{ section.settings.heading_weight }};
    color: {{ section.settings.heading_color }};
    margin: 0 0 {{ section.settings.heading_gap }}px;
    line-height: 1.2;
    word-wrap: break-word;
    text-align: {{ section.settings.heading_alignment }};
  }
  @media (min-width: 750px) {
    .rrev-{{ section.id }} .rrev-heading {
      font-size: {{ section.settings.heading_size }}px !important;
    }
  }

  .rrev-{{ section.id }} .rrev-overall {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    {% if section.settings.overall_alignment == 'center' %}justify-content: center;
    {% elsif section.settings.overall_alignment == 'right' %}justify-content: flex-end;
    {% else %}justify-content: flex-start;{% endif %}
  }
  .rrev-{{ section.id }} .rrev-overall-stars { display: flex; gap: 2px; align-items: center; }
  .rrev-{{ section.id }} .rrev-overall-star {
    font-size: {{ section.settings.overall_star_size }}px;
    color: {{ section.settings.heading_color }};
    line-height: 1;
  }
  .rrev-{{ section.id }} .rrev-overall-text {
    font-size: {{ section.settings.overall_text_size }}px;
    color: {{ section.settings.heading_color }};
    font-weight: 500;
  }

  /* ── Slider ── */
  .rrev-{{ section.id }} .rrev-slider {
    display: flex;
    align-items: stretch;
    overflow-x: auto;
    scroll-snap-type: x mandatory;

    scroll-padding-left: {{ section.settings.slider_inset_mobile }}px;
    gap: {{ section.settings.card_gap_mobile }}px;
    padding: 0 0 {{ section.settings.slider_pad_bottom_mobile }}px {{ section.settings.slider_inset_mobile }}px;
    scrollbar-width: none;
    -ms-overflow-style: none;
    box-sizing: border-box;
  }
  .rrev-{{ section.id }} .rrev-slider::-webkit-scrollbar { display: none; }
  .rrev-{{ section.id }} .rrev-slider::after {
    content: '';
    flex: 0 0 {{ section.settings.slider_inset_mobile }}px;
    height: 1px;
  }
  @media (min-width: 750px) {
    .rrev-{{ section.id }} .rrev-slider {
      gap: {{ section.settings.card_gap }}px;
      padding: 0 0 {{ section.settings.slider_pad_bottom }}px {{ section.settings.slider_inset }}px;
      scroll-padding-left: {{ section.settings.slider_inset }}px;
    }
    .rrev-{{ section.id }} .rrev-slider::after {
      flex: 0 0 {{ section.settings.slider_inset }}px;
    }
  }

  /* ── Cards ── */
  {%- assign cpv_m = section.settings.cards_per_view_mobile -%}
  {%- assign cpv_d = section.settings.cards_per_view -%}
  {%- assign card_pct_m = 100.0 | divided_by: cpv_m | round: 2 -%}
  {%- assign card_pct_d = 100.0 | divided_by: cpv_d | round: 2 -%}

  .rrev-{{ section.id }} .rrev-card {
    flex: 0 0 {{ card_pct_m }}%;
    scroll-snap-align: start;
    background: {{ section.settings.card_bg }};
    border-radius: {{ section.settings.card_radius }}px;
    padding: {{ section.settings.card_pad_mobile }}px;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    min-height: {{ section.settings.card_min_height_mobile }}px;
  }
  @media (min-width: 750px) {
    .rrev-{{ section.id }} .rrev-card {
      flex: 0 0 {{ card_pct_d }}%;
      padding: {{ section.settings.card_pad }}px;
      min-height: {{ section.settings.card_min_height }}px;
    }
  }

  .rrev-{{ section.id }} .rrev-card-title {
    font-size: {{ section.settings.card_title_size_mobile }}px !important;
    font-weight: {{ section.settings.card_title_weight }};
    color: {{ section.settings.card_title_color }};
    margin: 0 0 {{ section.settings.card_title_gap }}px;
    line-height: 1.3;
    word-wrap: break-word;
  }
  @media (min-width: 750px) {
    .rrev-{{ section.id }} .rrev-card-title {
      font-size: {{ section.settings.card_title_size }}px !important;
    }
  }

  /* ── Trustpilot stars ── */
  .rrev-{{ section.id }} .rrev-stars-row {
    display: flex;
    align-items: center;
    gap: {{ section.settings.stars_score_gap }}px;
    margin-bottom: {{ section.settings.stars_gap }}px;
  }
  .rrev-{{ section.id }} .rrev-tp-stars { display: flex; gap: 2px; }
  .rrev-{{ section.id }} .rrev-tp-star {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: {{ section.settings.star_size }}px;
    height: {{ section.settings.star_size }}px;
    background: {{ section.settings.star_color }};
    border-radius: {{ section.settings.star_radius }}px;
    color: #ffffff;
    font-size: {{ section.settings.star_size | times: 65 | divided_by: 100 }}px;
    line-height: 1;
    flex-shrink: 0;
  }
  .rrev-{{ section.id }} .rrev-tp-star--empty { background: #dcdce6; }
  .rrev-{{ section.id }} .rrev-tp-star--partial {
    background: linear-gradient(to right, {{ section.settings.star_color }} var(--pct), #dcdce6 var(--pct));
  }
  .rrev-{{ section.id }} .rrev-score {
    font-size: {{ section.settings.card_score_size }}px;
    font-weight: 600;
    color: {{ section.settings.card_text_color }};
  }

  /* ── Body ── */
  .rrev-{{ section.id }} .rrev-body {
    font-size: {{ section.settings.card_text_size_mobile }}px;
    color: {{ section.settings.card_text_color }};
    line-height: 1.65;
    word-wrap: break-word;
    margin: 0;
  }
  .rrev-{{ section.id }} .rrev-body p { margin: 0; }
  @media (min-width: 750px) {
    .rrev-{{ section.id }} .rrev-body { font-size: {{ section.settings.card_text_size }}px; }
  }

  /* ── Reviewer ── */
  .rrev-{{ section.id }} .rrev-reviewer {
    display: flex;
    align-items: center;
    gap: {{ section.settings.reviewer_gap }}px;
    margin-top: auto;
    padding-top: {{ section.settings.reviewer_margin_top }}px;
  }
  .rrev-{{ section.id }} .rrev-avatar,
  .rrev-{{ section.id }} .rrev-avatar-placeholder {
    width: {{ section.settings.avatar_size }}px;
    height: {{ section.settings.avatar_size }}px;
    border-radius: 50%;
    flex-shrink: 0;
    object-fit: cover;
    display: block;
    background: {{ section.settings.avatar_bg }};
  }
  .rrev-{{ section.id }} .rrev-info { display: flex; flex-direction: column; gap: 2px; }
  .rrev-{{ section.id }} .rrev-name {
    font-size: {{ section.settings.reviewer_name_size }}px;
    font-weight: 600;
    color: {{ section.settings.card_text_color }};
    margin: 0; line-height: 1.3;
  }
  .rrev-{{ section.id }} .rrev-verified {
    font-size: {{ section.settings.reviewer_verified_size }}px;
    font-weight: 500;
    color: {{ section.settings.verified_color }};
    margin: 0; line-height: 1.3;
  }
  .rrev-{{ section.id }} .rrev-date {
    font-size: {{ section.settings.reviewer_date_size }}px;
    color: {{ section.settings.reviewer_date_color }};
    margin: 0; line-height: 1.3;
  }

  /* ── Navigation ── */
  .rrev-{{ section.id }} .rrev-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: {{ section.settings.nav_gap }}px;
    padding-top: {{ section.settings.nav_pad_top }}px;
  }
  .rrev-{{ section.id }} .rrev-nav-btn {
    width: {{ section.settings.nav_btn_size }}px;
    height: {{ section.settings.nav_btn_size }}px;
    border-radius: 50%;
    border: 1px solid {{ section.settings.nav_btn_border_color }};
    background: {{ section.settings.nav_btn_bg }};
    color: {{ section.settings.nav_btn_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: opacity 0.2s;
    flex-shrink: 0;
    padding: 0;
  }
  .rrev-{{ section.id }} .rrev-nav-btn:disabled { opacity: 0.35; cursor: default; }
  .rrev-{{ section.id }} .rrev-nav-btn:not(:disabled):hover { opacity: 0.75; }
  .rrev-{{ section.id }} .rrev-nav-btn svg { width: 18px; height: 18px; }
{%- endstyle -%}

<div class="rrev-{{ section.id }}">

  <div class="rrev-header">
    {%- if section.settings.heading != blank -%}
      <{{ section.settings.heading_tag }} class="rrev-heading">{{ section.settings.heading }}</{{ section.settings.heading_tag }}>
    {%- endif -%}
    {%- if section.settings.overall_rating_text != blank -%}
      <div class="rrev-overall">
        <div class="rrev-overall-stars">
          {%- for i in (1..5) -%}<span class="rrev-overall-star">★</span>{%- endfor -%}
        </div>
        <span class="rrev-overall-text">{{ section.settings.overall_rating_text }}</span>
      </div>
    {%- endif -%}
  </div>

  <div class="rrev-slider" id="rrev-slider-{{ section.id }}">
    {%- for block in section.blocks -%}
      {%- assign r_full = block.settings.rating | floor -%}
      {%- assign r_dec  = block.settings.rating | minus: r_full -%}
      {%- assign r_next = r_full | plus: 1 -%}
      {%- assign r_floor_check = block.settings.rating | floor -%}
      {%- if block.settings.rating == r_floor_check -%}
        {%- assign r_display = r_floor_check | append: '.0' -%}
      {%- else -%}
        {%- assign r_display = block.settings.rating -%}
      {%- endif -%}
      <div class="rrev-card" {{ block.shopify_attributes }}>
        {%- if block.settings.title != blank -%}
          <{{ section.settings.card_title_tag }} class="rrev-card-title">{{ block.settings.title }}</{{ section.settings.card_title_tag }}>
        {%- endif -%}

        <div class="rrev-stars-row">
          <div class="rrev-tp-stars">
            {%- for i in (1..5) -%}
              {%- if i <= r_full -%}
                <span class="rrev-tp-star">★</span>
              {%- elsif i == r_next and r_dec > 0 -%}
                {%- assign pct_val = r_dec | times: 100 | round -%}
                <span class="rrev-tp-star rrev-tp-star--partial" style="--pct: {{ pct_val }}%">★</span>
              {%- else -%}
                <span class="rrev-tp-star rrev-tp-star--empty">★</span>
              {%- endif -%}
            {%- endfor -%}
          </div>
          <span class="rrev-score">{{ r_display }}</span>
        </div>

        {%- if block.settings.body != blank -%}
          <div class="rrev-body">{{ block.settings.body }}</div>
        {%- endif -%}

        <div class="rrev-reviewer">
          {%- if block.settings.avatar != blank -%}
            {{ block.settings.avatar | image_url: width: 120 | image_tag: class: 'rrev-avatar', loading: 'lazy', alt: block.settings.reviewer_name }}
          {%- else -%}
            <div class="rrev-avatar-placeholder"></div>
          {%- endif -%}
          <div class="rrev-info">
            {%- if block.settings.reviewer_name != blank -%}
              <p class="rrev-name">{{ block.settings.reviewer_name }}</p>
            {%- endif -%}
            {%- if block.settings.verified_text != blank -%}
              <p class="rrev-verified">{{ block.settings.verified_text }}</p>
            {%- endif -%}
            {%- if block.settings.date != blank -%}
              <p class="rrev-date">{{ block.settings.date }}</p>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>

  <div class="rrev-nav">
    <button class="rrev-nav-btn" id="rrev-prev-{{ section.id }}" aria-label="Previous" disabled>
      <svg viewBox="0 0 18 18" fill="none"><path d="M11 4L6 9L11 14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <button class="rrev-nav-btn" id="rrev-next-{{ section.id }}" aria-label="Next">
      <svg viewBox="0 0 18 18" fill="none"><path d="M7 4L12 9L7 14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
  </div>

</div>

<script>
(function() {
  var slider = document.getElementById('rrev-slider-{{ section.id }}');
  var prev   = document.getElementById('rrev-prev-{{ section.id }}');
  var next   = document.getElementById('rrev-next-{{ section.id }}');
  if (!slider) return;

  function cardStep() {
    var card = slider.querySelector('.rrev-card');
    if (!card) return slider.clientWidth;
    var gap = parseFloat(window.getComputedStyle(slider).gap) || 0;
    return card.offsetWidth + gap;
  }

  function updateButtons() {
    var max = slider.scrollWidth - slider.clientWidth;
    if (prev) prev.disabled = slider.scrollLeft <= 0;
    if (next) next.disabled = max <= 0 || slider.scrollLeft >= max - 1;
  }

  if (prev) prev.addEventListener('click', function() {
    slider.scrollBy({ left: -cardStep(), behavior: 'smooth' });
    setTimeout(updateButtons, 400);
  });
  if (next) next.addEventListener('click', function() {
    slider.scrollBy({ left: cardStep(), behavior: 'smooth' });
    setTimeout(updateButtons, 400);
  });
  slider.addEventListener('scroll', updateButtons, { passive: true });

  updateButtons();
})();
</script>

{% schema %}
{
  "name": "Romira — Reviews",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "color", "id": "section_bg", "label": "Section background color", "default": "#264165" },
    { "type": "header", "content": "Heading" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Hear from customers who trust Romira" },
    { "type": "select", "id": "heading_tag", "label": "Heading tag", "options": [{"value":"h1","label":"H1"},{"value":"h2","label":"H2"},{"value":"h3","label":"H3"}], "default": "h2" },
    { "type": "select", "id": "card_title_tag", "label": "Card title tag", "options": [{"value":"h2","label":"H2"},{"value":"h3","label":"H3"},{"value":"h4","label":"H4"}], "default": "h3" },
    { "type": "range", "id": "heading_size", "min": 20, "max": 72, "step": 1, "unit": "px", "label": "Heading size (desktop)", "default": 44 },
    { "type": "range", "id": "heading_size_mobile", "min": 18, "max": 52, "step": 1, "unit": "px", "label": "Heading size (mobile)", "default": 32 },
    { "type": "select", "id": "heading_weight", "label": "Heading weight", "options": [{"value":"400","label":"Regular"},{"value":"600","label":"Semi-bold"},{"value":"700","label":"Bold"},{"value":"800","label":"Extra bold"}], "default": "700" },
    { "type": "color", "id": "heading_color", "label": "Heading and rating text color", "default": "#ffffff" },
    { "type": "range", "id": "heading_gap", "min": 8, "max": 40, "step": 4, "unit": "px", "label": "Gap below heading", "default": 16 },
    { "type": "select", "id": "heading_alignment", "label": "Heading alignment", "options": [{"value":"left","label":"Left"},{"value":"center","label":"Center"},{"value":"right","label":"Right"}], "default": "center" },
