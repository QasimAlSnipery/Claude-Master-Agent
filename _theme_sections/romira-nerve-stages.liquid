{%- style -%}
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.background_color }} !important;
    overflow: clip;
    max-width: {{ section.settings.section_max_width }}px;
    width: 100%;
    margin-left: auto;
    margin-right: auto;
    padding-top: 0 !important;
    padding-bottom: 0 !important;
  }
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      max-width: {{ section.settings.section_max_width_mobile }}px;
    }
  }

  .romira-stages-{{ section.id }} {
    background-color: {{ section.settings.background_color }} !important;
    padding-top: {{ section.settings.mobile_padding_top }}px;
    padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    overflow: clip;
  }
  @media screen and (min-width: 750px) {
    .romira-stages-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .romira-stages-{{ section.id }} .rs-inner {
    max-width: {{ section.settings.content_width }}px;
    margin: 0 auto;
    padding: 0 {{ section.settings.horizontal_padding_mobile }}px;
    box-sizing: border-box;
  }
  @media screen and (min-width: 750px) {
    .romira-stages-{{ section.id }} .rs-inner {
      padding: 0 {{ section.settings.horizontal_padding }}px;
    }
  }

  /* ── Header ── */
  .romira-stages-{{ section.id }} .rs-header {
    text-align: {{ section.settings.heading_alignment }};
    margin-bottom: {{ section.settings.header_gap_mobile }}px;
  }
  @media screen and (min-width: 750px) {
    .romira-stages-{{ section.id }} .rs-header {
      margin-bottom: {{ section.settings.header_gap }}px;
    }
  }
  .romira-stages-{{ section.id }} .rs-heading {
    font-size: {{ section.settings.heading_size_mobile }}px;
    font-weight: {{ section.settings.heading_weight }};
    color: {{ section.settings.heading_color }};
    margin: 0 0 10px;
    line-height: 1.2;
    word-wrap: break-word;
  }
  @media screen and (min-width: 750px) {
    .romira-stages-{{ section.id }} .rs-heading { font-size: {{ section.settings.heading_size }}px; }
  }
  .romira-stages-{{ section.id }} .rs-subheading {
    font-size: {{ section.settings.subheading_size_mobile }}px;
    color: {{ section.settings.subheading_color }};
    margin: 0;
    line-height: 1.6;
  }
  @media screen and (min-width: 750px) {
    .romira-stages-{{ section.id }} .rs-subheading { font-size: {{ section.settings.subheading_size }}px; }
  }

  /* ── Stages container ── */
  .romira-stages-{{ section.id }} .rs-stages {
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.block_gap_mobile }}px;
  }
  @media screen and (min-width: 750px) {
    .romira-stages-{{ section.id }} .rs-stages {
      flex-direction: row;
      align-items: stretch;
      gap: {{ section.settings.block_gap }}px;
    }
  }

  /* ── Single stage card: image fills full height ── */
  .romira-stages-{{ section.id }} .rs-stage {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    flex: 1;
    min-width: 0;
    background: {{ section.settings.block_bg_color }};
    border-radius: {{ section.settings.stage_radius }}px;
    overflow: hidden;
  }

  /* ── Image wrapper: fills full height via stretch ── */
  .romira-stages-{{ section.id }} .rs-img-wrap {
    flex: 0 0 {{ section.settings.image_width_mobile }}%;
    position: relative;
    min-height: {{ section.settings.min_image_height_mobile }}px;
    overflow: hidden;
    background: {{ section.settings.img_placeholder_color }};
    flex-shrink: 0;
  }
  @media screen and (min-width: 750px) {
    .romira-stages-{{ section.id }} .rs-img-wrap {
      flex: 0 0 {{ section.settings.image_width }}%;
      min-height: {{ section.settings.min_image_height }}px;
    }
  }
  /* Image fills the wrapper completely */
  .romira-stages-{{ section.id }} .rs-img-wrap img {
    position: absolute;
    top: 0; left: 0;
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: {{ section.settings.img_position }};
  }
  .romira-stages-{{ section.id }} .rs-img-placeholder {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .romira-stages-{{ section.id }} .rs-img-placeholder svg {
    width: 36px; height: 36px; opacity: 0.25;
  }

  /* ── Stage content ── */
  .romira-stages-{{ section.id }} .rs-stage-content {
    flex: 1;
    min-width: 0;
    padding: {{ section.settings.stage_pad_v_mobile }}px {{ section.settings.stage_pad_h_mobile }}px;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    justify-content: {{ section.settings.content_valign }};
  }
  @media screen and (min-width: 750px) {
    .romira-stages-{{ section.id }} .rs-stage-content {
      padding: {{ section.settings.stage_pad_v }}px {{ section.settings.stage_pad_h }}px;
    }
  }

  .romira-stages-{{ section.id }} .rs-label {
    display: block;
    font-size: {{ section.settings.label_size }}px;
    font-weight: {{ section.settings.label_weight }};
    letter-spacing: {{ section.settings.label_spacing }}px;
    text-transform: {{ section.settings.label_transform }};
    color: {{ section.settings.stage_label_color }};
    margin: 0 0 {{ section.settings.label_gap }}px;
    line-height: 1.2;
  }
  .romira-stages-{{ section.id }} .rs-stage-heading {
    font-size: {{ section.settings.block_heading_size_mobile }}px;
    font-weight: {{ section.settings.block_heading_weight }};
    color: {{ section.settings.block_heading_color }};
    margin: 0 0 {{ section.settings.heading_body_gap }}px;
    line-height: 1.3;
    word-wrap: break-word;
  }
  @media screen and (min-width: 750px) {
    .romira-stages-{{ section.id }} .rs-stage-heading { font-size: {{ section.settings.block_heading_size }}px; }
  }
  .romira-stages-{{ section.id }} .rs-stage-text {
    font-size: {{ section.settings.block_text_size_mobile }}px;
    color: {{ section.settings.block_text_color }};
    line-height: 1.65;
    margin: 0;
    word-wrap: break-word;
  }
  @media screen and (min-width: 750px) {
    .romira-stages-{{ section.id }} .rs-stage-text { font-size: {{ section.settings.block_text_size }}px; }
  }
  .romira-stages-{{ section.id }} .rs-stage-text p { margin: 0 0 8px; }
  .romira-stages-{{ section.id }} .rs-stage-text p:last-child { margin: 0; }
  /* Scroll-in animations */
  .romira-stages-{{ section.id }} .rs-header { opacity: 0; transform: translateY(25px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .romira-stages-{{ section.id }} .rs-header.rs-in { opacity: 1; transform: translateY(0); }
  .romira-stages-{{ section.id }} .rs-stage { opacity: 0; transform: translateY(35px); transition: opacity 0.65s ease, transform 0.65s ease; }
  .romira-stages-{{ section.id }} .rs-stage.rs-in { opacity: 1; transform: translateY(0); }
  .romira-stages-{{ section.id }} .rs-stage:nth-child(1) { transition-delay: 0s; }
  .romira-stages-{{ section.id }} .rs-stage:nth-child(2) { transition-delay: 0.15s; }
  .romira-stages-{{ section.id }} .rs-stage:nth-child(3) { transition-delay: 0.3s; }
{%- endstyle -%}

<div class="romira-stages-{{ section.id }}">
  <div class="rs-inner">

    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="rs-header">
        {%- if section.settings.heading != blank -%}
          <{{ section.settings.heading_tag }} class="rs-heading">{{ section.settings.heading }}</{{ section.settings.heading_tag }}>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="rs-subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="rs-stages">
      {%- for block in section.blocks -%}
        <div class="rs-stage" {{ block.shopify_attributes }}>
          <div class="rs-img-wrap">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', alt: block.settings.heading }}
            {%- else -%}
              <div class="rs-img-placeholder">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/>
                </svg>
              </div>
            {%- endif -%}
          </div>
          <div class="rs-stage-content">
            {%- if block.settings.stage_label != blank -%}
              <span class="rs-label">{{ block.settings.stage_label }}</span>
            {%- endif -%}
            {%- if block.settings.heading != blank -%}
              <{{ section.settings.block_heading_tag }} class="rs-stage-heading">{{ block.settings.heading }}</{{ section.settings.block_heading_tag }}>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <div class="rs-stage-text">{{ block.settings.text }}</div>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>

  </div>
</div>

<script>
(function() {
  var header = document.querySelector('.romira-stages-{{ section.id }} .rs-header');
  var stages = document.querySelectorAll('.romira-stages-{{ section.id }} .rs-stage');
  var obs = new IntersectionObserver(function(entries, o) {
    entries.forEach(function(e) {
      if (e.isIntersecting) { e.target.classList.add('rs-in'); o.unobserve(e.target); }
    });
  }, { threshold: 0.12 });
  if (header) obs.observe(header);
  stages.forEach(function(s) { obs.observe(s); });
})();
</script>

