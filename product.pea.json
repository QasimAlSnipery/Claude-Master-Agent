        "content_padding_horizontal": 100,
        "content_padding_horizontal_mobile": 12,
        "heading": "<h2><strong>What Sets Romira PEA Apart?<\/strong><\/h2>",
        "heading_custom": false,
        "heading_font": "josefin_sans_n4",
        "heading_size": 50,
        "heading_size_mobile": 36,
        "heading_height": 110,
        "heading_align": "left",
