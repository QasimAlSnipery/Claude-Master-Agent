        "template--21507361800487__8beb6911-28c6-482c-976a-e5421ad3e8df-richtext-1": {
          "type": "richtext",
          "settings": {
            "column": "col_1",
            "visibility": "always-display",
            "text": "<p>Forged carbon fiber is the same material used in Formula 1 chassis and aerospace components. We put it on your wrist — because you deserve more than steel.<\/p>",
            "text_style": "body",
            "alignment": "center",
            "mobile_alignment": "mobile-center",
